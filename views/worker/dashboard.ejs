            <h2>🖨️ Предпросмотр бирки</h2>
            <div id="printPreviewContent" style="background:#fff; padding:20px; border-radius:8px; margin:15px 0; color:#000; text-align:left; font-family:Arial, sans-serif;">
                <div style="font-size:12px; color:#c9a959; font-weight:800; text-transform:uppercase; border-bottom:1px solid #eee; padding-bottom:5px; margin-bottom:8px;">
