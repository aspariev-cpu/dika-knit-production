                    font-weight: 800;
                    color: #c9a959;
                    letter-spacing: 0.5px;
                    text-transform: uppercase;
                }
                @media print {
                    html, body {
                        margin: 0;
                        padding: 0;
                        width: 56mm;
                        height: 32mm;
                    }
                }
            </style>
        </head>
        <body>
            <div class="label">
                <div class="title-row">
