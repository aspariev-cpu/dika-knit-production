    if (!taskCard) {
        alert('❌ Задание не найдено');
        return;
    }
    
    const modelName = taskCard.querySelector('.task-title')?.textContent?.trim() || 'Неизвестно';
    const color = taskCard.querySelector('.task-meta span:nth-child(3)')?.textContent?.replace('🎨', '').trim() || '—';
    const program = taskCard.querySelector('.task-meta span:nth-child(1)')?.textContent?.replace('📄', '').trim() || '—';
    const size = taskCard.querySelector('.task-meta span:nth-child(2)')?.textContent?.replace('📏', '').trim() || '—';
