    const machineSelect = taskCard.querySelector('select[name="machineId"]');
    const machineNumber = machineSelect ? machineSelect.value || '—' : '—';

    const title = modelName;

    const printWindow = window.open('', '_blank', 'width=400,height=300');
    if (!printWindow) {
        alert('❌ Разрешите всплывающие окна для печати');
        return;
    }

    printWindow.document.write(`
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset="UTF-8">
            <title>Этикетка Dika Knit</title>
            <style>
                * { margin: 0; padding: 0; box-sizing: border-box; }
                @page { size: 56mm 32mm; margin: 0; }
                html, body {
                    margin: 0;
                    padding: 0;
                    width: 56mm;
                    height: 32mm;
                    background: white;
                    display: flex;
                    justify-content: center;
                    align-items: flex-start;
                    font-family: Arial, Helvetica, sans-serif;
                }
                .label {
                    width: 56mm;
                    height: 32mm;
                    padding: 0.2mm 2.5mm 1mm 2.5mm;
                    border: none;
                    display: flex;
                    flex-direction: column;
                    justify-content: flex-start;
                    background: white;
                }
                .label .title-row {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    margin-bottom: 0.5px;
                }
                .label .model {
                    font-size: 14px;
                    font-weight: 700;
                    color: #000;
                    line-height: 1.1;
                }
                .label .urgent-badge {
                    font-size: 12px;
                    font-weight: 900;
                    color: #f87171;
                    white-space: nowrap;
                    margin-left: 8px;
                }
                .label .quantity {
                    font-size: 18px;
                    font-weight: 700;
                    color: #c9a959;
                    margin: 0px 0 0.5px 0;
                }
                .label .info {
                    font-size: 10px;
                    color: #333;
                    line-height: 1.2;
                }
                .label .info span {
                    font-weight: 600;
                    color: #000;
                }
                .label .color-dot {
                    display: inline-block;
                    width: 7px;
                    height: 7px;
                    border-radius: 50%;
                    vertical-align: middle;
                    margin-right: 2px;
                    border: 0.5px solid #ccc;
                }
                .label .bottom-section {
                    margin-top: auto;
                    border-top: 2px solid #c9a959;
