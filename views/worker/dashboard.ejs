            <\/script>
        </body>
        </html>
    `);
    printWindow.document.close();
}

        // ========================================
        //  ОТМЕНА
        // ========================================
        function undoOperation(taskId) {
            if (!taskId) {
                alert('❌ ID задания не указан');
                return;
            }

            if (!confirm('Отменить последнюю операцию для задания #' + taskId + '?')) {
                return;
            }

            fetch('/api/operations/undo/' + taskId, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Операция отменена');
                    location.reload();
                } else {
                    alert('❌ Ошибка: ' + (data.error || 'Неизвестная ошибка'));
                }
            })
            .catch(err => {
                alert('❌ Ошибка: ' + err.message);
            });
        }

        // ========================================
        //  ОТПРАВИТЬ АДМИНУ
        // ========================================
        async function sendToAdmin(taskId) {
            if (!confirm('Отправить задание администратору?')) return;
            
            try {
                const response = await fetch('/api/tasks/complete/' + taskId, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const result = await response.json();
                
                if (result.success) {
                    showNotification('✅ Задание отправлено администратору!', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    alert('❌ Ошибка: ' + (result.error || 'Неизвестная ошибка'));
                }
            } catch (err) {
                alert('❌ Ошибка: ' + err.message);
            }
        }

        // ========================================
        //  УВЕДОМЛЕНИЯ
        // ========================================
        function showNotification(message, type) {
            const colors = { success: '#4ade80', error: '#f87171', info: '#c9a959' };
            const notification = document.createElement('div');
            notification.style.cssText = `
                position: fixed;
                top: 80px;
                right: 20px;
                background: rgba(255,255,255,0.08);
                color: #fff;
                padding: 14px 20px;
                border-radius: 12px;
                border-left: 4px solid ${colors[type] || colors.info};
                box-shadow: 0 10px 30px rgba(0,0,0,0.4);
                font-size: 14px;
                font-weight: 500;
                animation: slideInRight 0.4s ease;
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255,255,255,0.05);
                z-index: 9999;
                max-width: 350px;
            `;
            notification.textContent = message;
            document.body.appendChild(notification);
            setTimeout(() => {
                notification.style.animation = 'slideOutRight 0.4s ease';
                setTimeout(() => notification.remove(), 400);
            }, 4000);
        }
    </script>
</body>
</html>