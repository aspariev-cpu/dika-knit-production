}

// ========================================
//  ПЕЧАТЬ (ШАПКИ) - исправленная
// ========================================
function printLabel(taskId) {
    // Берем количество из поля ввода
    const taskCard = document.querySelector(`.task-card[data-task-id="${taskId}"]`);
    if (!taskCard) {
        alert('❌ Задание не найдено');
        return;
    }
    
    const quantityInput = taskCard.querySelector('input[name="quantity"]');
    const quantity = quantityInput ? quantityInput.value || '0' : '0';
    
    if (quantity === '0' || quantity === '') {
        alert('⚠️ Введите количество перед печатью');
        return;
    }
    
    printLabelWithQuantity(taskId, quantity);
}

// ========================================
//  ПЕЧАТЬ ДЛЯ ДЕТАЛЕЙ КОФТЫ - исправленная
// ========================================
function printPartLabel(partId, partName) {
    const partBlock = document.querySelector(`.part-block[data-part-id="${partId}"]`);
    if (!partBlock) {
        alert('❌ Деталь не найдена');
        return;
    }
    
    const taskCard = partBlock.closest('.task-card');
    if (!taskCard) {
        alert('❌ Задание не найдено');
        return;
    }
    
    const quantityInput = partBlock.querySelector('input[name="quantity"]');
    const quantity = quantityInput ? quantityInput.value || '0' : '0';
    
    if (quantity === '0' || quantity === '') {
        alert('⚠️ Введите количество перед печатью');
        return;
    }
    
    const coatId = taskCard.dataset.taskId;
    printPartLabelWithQuantity(coatId, partId, partName, quantity);
}

// ========================================
//  ПЕЧАТЬ ДЕТАЛИ С ЗАДАННЫМ КОЛИЧЕСТВОМ
// ========================================
function printPartLabelWithQuantity(coatId, partId, partName, quantity) {
    const taskCard = document.querySelector(`.task-card[data-task-id="${coatId}"]`);
    if (!taskCard) {
        alert('❌ Задание не найдено');
        return;
    }
    
    const partBlock = document.querySelector(`.part-block[data-part-id="${partId}"]`);
    if (!partBlock) {
        alert('❌ Деталь не найдена');
        return;
    }
    
    const modelName = taskCard.querySelector('.task-title')?.textContent?.trim() || 'Неизвестно';
    const color = taskCard.querySelector('.task-meta span:nth-child(3)')?.textContent?.replace('🎨', '').trim() || '—';
    const program = partBlock.querySelector('.part-program')?.textContent?.trim() || '—';
    const size = taskCard.querySelector('.task-meta span:nth-child(2)')?.textContent?.replace('📏', '').trim() || '—';
    const className = taskCard.closest('.class-block')?.querySelector('.class-title')?.textContent?.replace('🔧 Класс', '').trim() || '—';
    const fullName = document.querySelector('.header-user')?.textContent?.trim() || 'Вязальщик';
    const date = new Date().toLocaleDateString('ru-RU', { timeZone: 'Europe/Moscow' });
    const ip = taskCard.dataset.ip || '—';
    const isUrgent = taskCard.dataset.urgent === 'true';
    
    const machineSelect = partBlock.querySelector('select[name="machineId"]');
    const machineNumber = machineSelect ? machineSelect.value || '—' : '—';

    const printWindow = window.open('', '_blank', 'width=400,height=300');
    if (!printWindow) {
        alert('❌ Разрешите всплывающие окна для печати');
        return;
    }

    printWindow.document.write(`
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset="UTF-8">
            <title>Этикетка Dika Knit - ${partName}</title>
            <style>
                * { margin: 0; padding: 0; box-sizing: border-box; }
                @page { size: 56mm 32mm; margin: 0; }
                html, body {
                    margin: 0;
                    padding: 0;
                    width: 56mm;
                    height: 32mm;
                    background: white;
                    display: flex;
                    justify-content: center;
                    align-items: flex-start;
                    font-family: Arial, Helvetica, sans-serif;
                }
                .label {
                    width: 56mm;
                    height: 32mm;
                    padding: 0.2mm 2.5mm 1mm 2.5mm;
                    border: none;
                    display: flex;
                    flex-direction: column;
                    justify-content: flex-start;
                    background: white;
                }
                .label .title-row {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    margin-bottom: 0.5px;
                }
                .label .model {
                    font-size: 13px;
                    font-weight: 700;
                    color: #000;
                    line-height: 1.1;
                }
                .label .urgent-badge {
                    font-size: 12px;
                    font-weight: 900;
                    color: #f87171;
                    white-space: nowrap;
                    margin-left: 8px;
                }
                .label .quantity {
                    font-size: 18px;
                    font-weight: 700;
                    color: #c9a959;
                    margin: 0px 0 0.5px 0;
                }
                .label .info {
                    font-size: 10px;
                    color: #333;
                    line-height: 1.2;
                }
                .label .info span {
                    font-weight: 600;
                    color: #000;
                }
                .label .color-dot {
                    display: inline-block;
                    width: 7px;
                    height: 7px;
                    border-radius: 50%;
                    vertical-align: middle;
                    margin-right: 2px;
                    border: 0.5px solid #ccc;
                }
                .label .bottom-section {
                    margin-top: auto;
                    border-top: 2px solid #c9a959;
                    padding-top: 1px;
                    text-align: center;
                    font-size: 9px;
                    font-weight: 800;
                    color: #c9a959;
                    letter-spacing: 0.5px;
                    text-transform: uppercase;
                }
                .label .part-badge {
                    display: inline-block;
                    background: #c9a959;
                    color: #000;
                    font-size: 8px;
                    font-weight: 700;
                    padding: 0 6px;
                    border-radius: 4px;
                    margin-left: 4px;
                    text-transform: uppercase;
                }
                @media print {
                    html, body {
                        margin: 0;
                        padding: 0;
                        width: 56mm;
                        height: 32mm;
                    }
                }
            </style>
        </head>
        <body>
            <div class="label">
                <div class="title-row">
                    <div class="model">${modelName} <span class="part-badge">${partName}</span></div>
