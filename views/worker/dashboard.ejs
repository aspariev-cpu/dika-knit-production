                <div style="font-size:8px; color:#aaa; border-top:1px solid #eee; padding-top:5px; margin-top:5px; text-align:center;">
                    Dika Knit Production
                </div>
            </div>
            <div class="modal-buttons">
                <button id="printPreviewBtn" class="btn btn-primary">🖨️ Печать</button>
                <button id="printPreviewCloseBtn" class="btn btn-secondary">✖️ Закрыть</button>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/main.js"></script>
    <script>
        // ========================================
        //  РАБОТА С СЕКЦИЯМИ
        // ========================================
        function toggleSection(section) {
            const body = document.getElementById(section + 'Body');
            const toggle = document.getElementById(section + 'Toggle');
            
            if (body.classList.contains('hidden')) {
                body.classList.remove('hidden');
                toggle.textContent = '−';
                localStorage.setItem('show' + section.charAt(0).toUpperCase() + section.slice(1), 'true');
            } else {
                body.classList.add('hidden');
                toggle.textContent = '+';
                localStorage.setItem('show' + section.charAt(0).toUpperCase() + section.slice(1), 'false');
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            const sections = ['shapki', 'coat'];
            sections.forEach(section => {
                const body = document.getElementById(section + 'Body');
                const toggle = document.getElementById(section + 'Toggle');
                if (body && toggle) {
                    const show = localStorage.getItem('show' + section.charAt(0).toUpperCase() + section.slice(1));
                    if (show === 'false') {
                        body.classList.add('hidden');
                        toggle.textContent = '+';
                    } else {
                        body.classList.remove('hidden');
                        toggle.textContent = '−';
                    }
                }
            });
        });

        // ========================================
        //  ФОТО
        // ========================================
        function openImageModal(imageSrc) {
            const modal = document.getElementById('imageModal');
            document.getElementById('modalImage').src = imageSrc;
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeImageModal() {
            document.getElementById('imageModal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        window.onclick = function(event) {
            const imageModal = document.getElementById('imageModal');
            const printModal = document.getElementById('printPreviewModal');
            if (event.target === imageModal) closeImageModal();
            if (event.target === printModal) {
                printModal.style.display = 'none';
            }
        };

        // ========================================
        //  ОТПРАВКА ВЫРАБОТКИ (ШАПКИ)
        // ========================================
        async function submitOperation(form) {
            const formData = new FormData(form);
            const data = {
                taskId: formData.get('taskId'),
                machineId: formData.get('machineId'),
                quantity: formData.get('quantity')
            };

            const btn = form.querySelector('button[type="submit"]');
            const originalText = btn.textContent;
            btn.textContent = '⏳...';
            btn.disabled = true;

            try {
                const response = await fetch('/api/operations', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();

                if (result.success) {
                    const taskId = data.taskId;
                    updateTaskProgress(taskId, result);
                    
                    const taskCard = document.querySelector(`.task-card[data-task-id="${taskId}"]`);
                    const modelName = taskCard?.querySelector('.task-title')?.textContent?.trim() || 'Неизвестно';
                    const color = taskCard?.querySelector('.task-meta span:nth-child(3)')?.textContent?.replace('🎨', '').trim() || '—';
                    const program = taskCard?.querySelector('.task-meta span:nth-child(1)')?.textContent?.replace('📄', '').trim() || '—';
                    const size = taskCard?.querySelector('.task-meta span:nth-child(2)')?.textContent?.replace('📏', '').trim() || '—';
                    const className = taskCard?.closest('.class-block')?.querySelector('.class-title')?.textContent?.replace('🔧 Класс', '').trim() || '—';
                    const yarn = taskCard?.querySelector('.task-meta strong')?.textContent?.trim() || '—';
                    
                    showPreview({
                        modelName: modelName,
                        partName: null,
                        quantity: data.quantity,
                        program: program,
                        size: size,
                        color: color,
                        className: className,
                        yarn: yarn,
                        taskId: data.taskId,
                        operationId: result.operationId,
                        machineId: result.machineId
                    });
                    
                    showNotification(`✅ +${data.quantity} шт.`, 'success');
                    form.querySelector('input[name="quantity"]').value = '';
                } else {
                    alert('❌ Ошибка: ' + (result.error || 'Неизвестная ошибка'));
                }
            } catch (err) {
                alert('❌ Ошибка: ' + err.message);
            } finally {
                btn.textContent = originalText;
                btn.disabled = false;
            }
        }

        // ========================================
//  ОТПРАВКА ВЫРАБОТКИ (ДЕТАЛИ КОФТЫ) - ИСПРАВЛЕННАЯ
// ========================================
async function submitOperationPart(form, partId) {
    const formData = new FormData(form);
    
    // НАХОДИМ КАРТОЧКУ КОФТЫ
    const partBlock = document.querySelector(`.part-block[data-part-id="${partId}"]`);
    const taskCard = partBlock?.closest('.task-card');
    const coatId = taskCard?.dataset.taskId;
    
    if (!coatId) {
        alert('❌ ID кофты не найден');
        return;
    }
    
    const data = {
        taskId: coatId,        // ← ID кофты (для поиска)
        partId: partId,        // ← ID детали (для сохранения операции)
        machineId: formData.get('machineId'),
        quantity: formData.get('quantity')
    };

    const btn = form.querySelector('button[type="submit"]');
    const originalText = btn.textContent;
    btn.textContent = '⏳...';
    btn.disabled = true;

    try {
        const response = await fetch('/api/operations', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        const result = await response.json();

        if (result.success) {
            // Обновляем прогресс детали
            if (partBlock) {
                const progressText = partBlock.querySelector('.part-progress .value');
                const percentText = partBlock.querySelector('.part-progress span:last-child');
                const progressFillBar = partBlock.querySelector('.part-progress-bar .fill');
                const partPercent = Math.min((result.totalDone / result.planQuantity) * 100, 100);
                if (progressText) progressText.textContent = `${result.totalDone}/${result.planQuantity}`;
                if (percentText) percentText.textContent = `${Math.round(partPercent)}%`;
                if (progressFillBar) progressFillBar.style.width = partPercent + '%';
            }

            // Обновляем общий прогресс кофты
            if (result.parentProgress) {
                updateCoatProgress(coatId, result.parentProgress);
            }

            // Показываем предпросмотр
            const modelName = taskCard?.querySelector('.task-title')?.textContent?.trim() || 'Неизвестно';
            const color = taskCard?.querySelector('.task-meta span:nth-child(3)')?.textContent?.replace('🎨', '').trim() || '—';
            const program = partBlock?.querySelector('.part-program')?.textContent?.trim() || '—';
            const size = taskCard?.querySelector('.task-meta span:nth-child(2)')?.textContent?.replace('📏', '').trim() || '—';
            const className = taskCard?.closest('.class-block')?.querySelector('.class-title')?.textContent?.replace('🔧 Класс', '').trim() || '—';
            const partName = partBlock?.querySelector('.part-name')?.textContent?.trim() || 'Деталь';
            
            showPreview({
                modelName: modelName,
                partName: partName,
                quantity: data.quantity,
                program: program,
                size: size,
                color: color,
                className: className,
                yarn: taskCard?.querySelector('.task-meta strong')?.textContent?.trim() || '—',
                taskId: data.taskId,
                operationId: result.operationId,
                machineId: result.machineId
            });

            showNotification(`✅ +${data.quantity} шт. для детали`, 'success');
            form.querySelector('input[name="quantity"]').value = '';
        } else {
            alert('❌ Ошибка: ' + (result.error || 'Неизвестная ошибка'));
        }
    } catch (err) {
        alert('❌ Ошибка: ' + err.message);
    } finally {
        btn.textContent = originalText;
        btn.disabled = false;
    }
}

        // ========================================
        //  ОБНОВЛЕНИЕ ПРОГРЕССА ЗАДАНИЯ
        // ========================================
        function updateTaskProgress(taskId, result) {
            const doneElement = document.getElementById('done-' + taskId);
            const percentElement = document.getElementById('percent-' + taskId);
            const progressFill = document.getElementById('progress-fill-' + taskId);
            const progressText = document.getElementById('progress-text-' + taskId);

            if (doneElement) doneElement.textContent = result.totalDone;
            if (percentElement) percentElement.textContent = Math.round(result.percent);
            if (progressFill) progressFill.style.width = result.percent + '%';
            
            if (progressText) {
                progressText.innerHTML = `<strong style="color: #fff;" id="done-${taskId}">${result.totalDone}</strong> из <strong style="color: #c9a959;">${result.planQuantity}</strong> шт. (<span id="percent-${taskId}">${Math.round(result.percent)}</span>%)`;
            }

            const sendBtn = document.getElementById('send-btn-' + taskId);
            if (sendBtn) {
                sendBtn.style.display = result.percent >= 100 ? 'block' : 'none';
            }
        }

        // ========================================
        //  ОБНОВЛЕНИЕ ПРОГРЕССА КОФТЫ
        // ========================================
        function updateCoatProgress(coatId, progress) {
            const doneElement = document.getElementById('done-' + coatId);
            const percentElement = document.getElementById('percent-' + coatId);
            const progressFill = document.getElementById('progress-fill-' + coatId);
            const progressText = document.getElementById('progress-text-' + coatId);

            if (doneElement) doneElement.textContent = progress.totalDone;
            if (percentElement) percentElement.textContent = Math.round(progress.percent);
            if (progressFill) progressFill.style.width = progress.percent + '%';
            
            if (progressText) {
                progressText.innerHTML = `<strong style="color: #fff;" id="done-${coatId}">${progress.totalDone}</strong> из <strong style="color: #c9a959;">${progress.totalPlan}</strong> шт. (<span id="percent-${coatId}">${Math.round(progress.percent)}</span>%)`;
            }

            const sendBtn = document.getElementById('send-btn-' + coatId);
            if (sendBtn) {
                sendBtn.style.display = progress.percent >= 100 ? 'block' : 'none';
            }
        }

        // ========================================
//  ПРЕДПРОСМОТР (исправленный)
// ========================================
let pendingPrintData = null; // сохраняем данные для печати

function showPreview(data) {
    const modal = document.getElementById('printPreviewModal');
    document.getElementById('previewModel').textContent = data.modelName + (data.partName ? ` (${data.partName})` : '');
    document.getElementById('previewDetails').innerHTML = `
        Цвет: ${data.color || '—'} | Класс: ${data.className || '—'}<br>
        Программа: ${data.program || '—'}<br>
        Размер: ${data.size || '—'} | Пряжа: ${data.yarn || '—'}
    `;
    document.getElementById('previewQuantity').textContent = `📦 ${data.quantity} шт.`;
    
    // Сохраняем данные для печати
    pendingPrintData = data;
    modal.dataset.taskId = data.taskId;
    modal.dataset.operationId = data.operationId;
    modal.dataset.quantity = data.quantity;
    modal.style.display = 'flex';
    
    // Кнопка печати
    document.getElementById('printPreviewBtn').onclick = function() {
        const quantity = pendingPrintData?.quantity || modal.dataset.quantity || '0';
        printLabelWithQuantity(modal.dataset.taskId, quantity);
        modal.style.display = 'none';
        showNotification('🖨️ Этикетка отправлена на печать', 'success');
    };
    
    // Кнопка закрыть
    document.getElementById('printPreviewCloseBtn').onclick = function() {
        modal.style.display = 'none';
        showNotification('💾 Выработка сохранена', 'info');
    };
}

// ========================================
//  ПЕЧАТЬ С ЗАДАННЫМ КОЛИЧЕСТВОМ
// ========================================
function printLabelWithQuantity(taskId, quantity) {
