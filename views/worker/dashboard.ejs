<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Вязальщик</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <span class="header-user">
                <span class="avatar"><%= user.fullName ? user.fullName.charAt(0).toUpperCase() : 'U' %></span>
                <%= user.fullName || 'Вязальщик' %>
            </span>
            <a href="/logout" class="logout-btn">Выйти</a>
        </div>
    </div>

    <div class="container">
        <h1 class="page-title">🧵 Мои задания</h1>
        
        <div class="tasks-grid">
            <% if (tasks && tasks.length > 0) { %>
                <% tasks.forEach(function(task) {
                    let totalDone = 0;
                    let totalPlan = 0;
                    let allDone = true;
                    if (task.programs) {
                        task.programs.forEach(function(p) {
                            totalDone += p.doneQuantity;
                            totalPlan += p.planQuantity;
                            if (p.doneQuantity < p.planQuantity) allDone = false;
                        });
                    }
                    let totalPercent = totalPlan > 0 ? Math.min((totalDone / totalPlan) * 100, 100) : 0;
                    let isUrgent = task.isUrgent;
                %>
                <div class="task-card <%= isUrgent ? 'urgent' : '' %>" data-task-id="<%= task.id %>">
                    <div class="task-title">
                        <% if (isUrgent) { %>
                            <span class="urgent-badge">🔥</span>
                        <% } %>
                        <%= task.modelName %>
                    </div>
                    <div class="task-meta">
                        Цвет: <span class="color-dot" style="background:<%= task.color %>;"></span> <%= task.color %> | 
                        Класс: <strong><%= task.className %></strong>
                    </div>
                    
                    <% if (task.programs && task.programs.length > 0) { %>
                        <% task.programs.forEach(function(program) {
                            let progPercent = Math.min((program.doneQuantity / program.planQuantity) * 100, 100);
                            let progDone = program.doneQuantity >= program.planQuantity;
                        %>
                            <div style="margin-top: 10px; padding: 8px 12px; background: rgba(255,255,255,0.03); border-radius: 8px;">
                                <div style="display: flex; justify-content: space-between; font-size: 13px;">
                                    <span><%= program.name %> (<%= program.programFile %>)</span>
                                    <span><%= program.doneQuantity %>/<%= program.planQuantity %> шт. <%= progDone ? '✅' : '' %></span>
                                </div>
                                <div class="task-progress" style="height:6px; margin:4px 0;">
                                    <div class="task-progress-fill" style="width:<%= progPercent %>%;"></div>
                                </div>
                                <div style="display: flex; gap: 8px; margin-top: 4px; flex-wrap: wrap;">
                                    <button class="btn btn-primary btn-sm" onclick="openModal('<%= task.id %>', '<%= program.id %>', '<%= program.name %>')" style="padding:4px 12px; font-size:12px;">
                                        📝 Ввести кол-во
                                    </button>
                                    <button class="btn btn-secondary btn-sm print-btn" data-task-id="<%= task.id %>" data-program-id="<%= program.id %>" onclick="printLabel('<%= task.id %>', '<%= program.id %>')" style="padding:4px 12px; font-size:12px;">
                                        🖨️ Печать
                                    </button>
                                </div>
                            </div>
                        <% }); %>
                    <% } %>
                    
                    <!-- Общий прогресс -->
                    <div style="margin-top: 12px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.05);">
                        <div style="display: flex; justify-content: space-between; font-size: 13px; color: #c9a959;">
                            <span>📊 Общий прогресс</span>
                            <span><%= totalDone %> из <%= totalPlan %> шт. (<%= Math.round(totalPercent) %>%)</span>
                        </div>
                        <div class="task-progress" style="height:8px; margin-top:4px;">
                            <div class="task-progress-fill" style="width:<%= totalPercent %>%;"></div>
                        </div>
                    </div>
                    
                    <!-- Кнопка отмены, если все детали выполнены -->
                    <% if (allDone && task.lastPrintedAt) { 
                        const now = new Date();
                        const printed = new Date(task.lastPrintedAt);
                        const diffMs = now - printed;
                        const diffMinutes = diffMs / (1000 * 60);
                        const canUndo = diffMinutes < 60;
                    %>
                        <div style="margin-top: 10px; padding: 10px 14px; background: rgba(81,207,102,0.1); border-radius: 8px; border-left: 3px solid #51cf66;">
                            <div style="font-size: 13px; color: #51cf66; font-weight: 600;">✅ Все детали выполнены!</div>
                            <div style="font-size: 12px; color: #888;">
                                ⏳ Автоматическое завершение через: <span id="timer-<%= task.id %>" style="color: #c9a959; font-weight: 600;">--:--</span>
                            </div>
                            <% if (canUndo) { %>
                                <form action="/api/operations/undo/<%= task.id %>" method="post" style="margin-top: 8px;" 
                                      onsubmit="return confirm('⚠️ Отменить последнюю операцию? Это действие нельзя будет отменить.')">
                                    <button type="submit" class="btn btn-danger btn-sm" style="padding:6px 14px; font-size:12px; border-radius:6px; border:none; cursor:pointer; background:#ff6b6b; color:#fff;">
                                        ↩️ Отменить последнее действие
                                    </button>
                                </form>
                            <% } else { %>
                                <div style="margin-top: 8px; font-size: 12px; color: #ff6b6b;">
                                    ⏰ Время на отмену истекло
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                    
                    <% if (allDone && !task.lastPrintedAt) { %>
                        <div style="margin-top: 10px; padding: 10px 14px; background: rgba(255,193,7,0.1); border-radius: 8px; border-left: 3px solid #ffc107;">
                            <div style="font-size: 13px; color: #ffc107; font-weight: 600;">✅ Все детали выполнены!</div>
                            <div style="font-size: 12px; color: #888;">
                                ⚠️ Напечатайте этикетку, чтобы запустить таймер завершения
                            </div>
                        </div>
                    <% } %>
                </div>
                <% }); %>
            <% } else { %>
                <div style="text-align: center; padding: 60px 20px; color: #666; grid-column: 1/-1;">
                    <p style="font-size: 48px; margin-bottom: 20px;">📭</p>
                    <p style="font-size: 18px; color: #888;">Нет активных заданий</p>
                    <p style="color: #555; margin-top: 10px;">Ожидайте новых задач от администратора</p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- МОДАЛЬНОЕ ОКНО -->
    <div id="modal" class="modal">
        <div class="modal-content">
            <h2 id="modalTitle">📦 Ввод количества</h2>
            <form action="/api/operations" method="post" id="operationForm">
                <input type="hidden" name="taskId" id="taskId" value="">
                <input type="hidden" name="programId" id="programId" value="">
                
                <select name="machineId" required style="width:100%; padding:12px 16px; margin-bottom:15px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,215,0,0.15); border-radius:10px; color:#fff; font-size:14px;">
                    <option value="">Выберите станок</option>
                    <% for (let i = 1; i <= 15; i++) { %>
                        <option value="<%= i %>" style="background:#1a1a2e; color:#fff; padding:8px;">Станок №<%= i %></option>
                    <% } %>
                </select>
                <input type="number" name="quantity" placeholder="Количество (шт.)" min="1" required style="width:100%; padding:12px 16px; margin-bottom:15px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,215,0,0.15); border-radius:10px; color:#fff; font-size:14px;">
                
                <div class="modal-buttons">
                    <button type="submit" class="btn btn-primary">💾 Сохранить</button>
                    <button type="button" class="btn btn-secondary" onclick="closeModal()">Отмена</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/main.js"></script>
    
    <script>
        // Таймеры
        document.querySelectorAll('.task-card').forEach(function(card) {
            const taskId = card.dataset.taskId;
            const timerElement = document.getElementById('timer-' + taskId);
            const lastPrintedAt = card.querySelector('[data-last-printed]')?.dataset?.lastPrinted;
            
            if (timerElement && lastPrintedAt) {
                updateTimer(timerElement, lastPrintedAt);
                setInterval(function() {
                    updateTimer(timerElement, lastPrintedAt);
                }, 1000);
            }
        });
        
        function updateTimer(element, lastPrintedAt) {
            const now = new Date();
            const printed = new Date(lastPrintedAt);
            const diffMs = now - printed;
            const diffMinutes = diffMs / (1000 * 60);
            
            if (diffMinutes >= 60) {
                element.textContent = '⏳ Завершено';
                element.style.color = '#51cf66';
            } else {
                const remaining = 60 - diffMinutes;
                const mins = Math.floor(remaining);
                const secs = Math.floor((remaining - mins) * 60);
                element.textContent = String(mins).padStart(2, '0') + ':' + String(secs).padStart(2, '0');
                element.style.color = '#c9a959';
            }
        }
        
        function openModal(taskId, programId, programName) {
            console.log('🔍 openModal вызван:', { taskId, programId, programName });
            
            const modal = document.getElementById('modal');
            if (!modal) {
                console.error('❌ Модальное окно не найдено');
                alert('Ошибка: модальное окно не найдено');
                return;
            }
            
            const taskIdInput = document.getElementById('taskId');
            const programIdInput = document.getElementById('programId');
            const title = document.getElementById('modalTitle');
            
            if (!taskIdInput || !programIdInput || !title) {
                console.error('❌ Элементы формы не найдены');
                alert('Ошибка: элементы формы не найдены');
                return;
            }
            
            taskIdInput.value = taskId;
            programIdInput.value = programId;
            title.textContent = '📦 ' + programName;
            
            console.log('✅ Установлены значения:', {
                taskId: taskIdInput.value,
                programId: programIdInput.value
            });
            
            modal.classList.add('active');
        }
        
        function closeModal() {
            const modal = document.getElementById('modal');
            if (modal) {
                modal.classList.remove('active');
            }
        }
        
        function printLabel(taskId, programId) {
            alert('🖨️ Печать этикетки\nЗадание: ' + taskId + '\nДеталь: ' + programId);
        }
        
        window.onclick = function(event) {
            const modal = document.getElementById('modal');
            if (event.target === modal) {
                closeModal();
            }
        };
        
        console.log('🧵 Dika Knit - Страница вязальщика загружена');
    </script>
</body>
</html>
