<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Вязальщик</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <span class="header-user">
                <span class="avatar"><%= user.fullName ? user.fullName.charAt(0).toUpperCase() : 'U' %></span>
                <%= user.fullName || 'Вязальщик' %>
            </span>
            <a href="/logout" class="logout-btn">Выйти</a>
        </div>
    </div>

    <div class="container">
        <h1 class="page-title">🧵 Мои задания</h1>
        
        <div class="tasks-grid">
            <% if (tasks && tasks.length > 0) { %>
                <% tasks.forEach(function(task) { 
                    let done = 0;
                    if (task.operations) {
                        task.operations.forEach(function(o) { done += o.quantity; });
                    }
                    let percent = Math.min((done / task.planQuantity) * 100, 100);
                    let isUrgent = task.isUrgent;
                    let isCompleted = done >= task.planQuantity;
                %>
                <div class="task-card <%= isUrgent ? 'urgent' : '' %>" 
                     data-task-id="<%= task.id %>"
                     data-model="<%= task.modelName %>"
                     data-color="<%= task.color %>"
                     data-program="<%= task.programFile %>"
                     data-class="<%= task.className %>"
                     data-quantity="<%= task.planQuantity %>"
                     data-worker="<%= user.fullName || 'Вязальщик' %>"
                     data-last-printed="<%= task.lastPrintedAt || '' %>">
                    
                    <div class="task-title">
                        <% if (isUrgent) { %>
                            <span class="urgent-badge">🔥</span>
                        <% } %>
                        <%= task.modelName %>
                    </div>
                    <div class="task-meta">
                        Программа: <strong><%= task.programFile %></strong> | 
                        Цвет: <span class="color-dot" style="background:<%= task.color %>;"></span> <%= task.color %>
                    </div>
                    <div class="task-meta">Класс: <strong><%= task.className %></strong></div>
                    
                    <div class="task-progress">
                        <div class="task-progress-fill" style="width:<%= percent %>%;"></div>
                    </div>
                    <div class="task-stats">
                        <span><%= done %> из <%= task.planQuantity %> шт.</span>
                        <span><%= Math.round(percent) %>%</span>
                    </div>
                    
                    <% if (isCompleted && task.lastPrintedAt) { 
                        const now = new Date();
                        const printed = new Date(task.lastPrintedAt);
                        const diffMs = now - printed;
                        const diffMinutes = diffMs / (1000 * 60);
                        const canUndo = diffMinutes < 60;
                    %>
