<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Админ</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .searchable-select {
            width: 100%;
            padding: 12px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(201,169,89,0.1);
            border-radius: 10px;
            color: #fff;
        }
        .searchable-select:focus {
            outline: none;
            border-color: #c9a959;
            background: rgba(255,255,255,0.1);
            box-shadow: 0 0 0 4px rgba(201,169,89,0.1);
        }
        .searchable-select option {
            padding: 8px 12px;
        }
        .searchable-select option:hover {
            background: rgba(201,169,89,0.2) !important;
        }
        .search-wrapper {
            position: relative;
            width: 100%;
        }
        .search-wrapper input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(201,169,89,0.1);
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
        }
        .search-wrapper input:focus {
            outline: none;
            border-color: #c9a959;
            background: rgba(255,255,255,0.1);
        }
        .search-results {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: #1a1f36;
            border: 1px solid rgba(201,169,89,0.2);
            border-radius: 10px;
            max-height: 200px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
            margin-top: 4px;
        }
        .search-results .result-item {
            padding: 10px 16px;
            color: #fff;
            cursor: pointer;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .search-results .result-item:hover {
            background: #f5f0e6;
            color: #dc2626;
        }
        .search-results .result-item:hover .sub {
            color: #dc2626;
        }
        .search-results .result-item:last-child {
            border-bottom: none;
        }
        .search-results .result-item .sub {
            color: #8892b0;
            font-size: 12px;
            margin-left: 8px;
        }
        .selected-value {
            margin-top: 8px;
            padding: 8px 12px;
            background: rgba(201,169,89,0.1);
            border-radius: 6px;
            color: #c9a959;
            display: none;
        }
        .coat-parts-info {
            font-size: 11px;
            color: #8892b0;
        }
        .coat-parts-info .part-item {
            display: inline-block;
            background: rgba(201,169,89,0.1);
            padding: 1px 8px;
            border-radius: 10px;
            margin: 1px 2px;
            font-size: 10px;
            color: #c9a959;
        }
        .coat-progress-bar {
            height: 4px;
            background: rgba(255,255,255,0.08);
            border-radius: 2px;
            overflow: hidden;
            margin-top: 2px;
            width: 80px;
            display: inline-block;
            vertical-align: middle;
        }
        .coat-progress-bar .fill {
            height: 100%;
            background: linear-gradient(90deg, #c9a959, #e8c97a);
            border-radius: 2px;
            transition: width 0.3s ease;
        }
        .coat-progress-text {
            font-size: 12px;
            color: #8892b0;
            margin-left: 4px;
        }
        #coatPartsFields {
           display: grid;
           grid-template-columns: 1fr;
           gap: 10px;
}
        .coat-part-field {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .coat-part-field label {
            color: #fff;
            font-weight: 500;
            min-width: 80px;
        }
        .coat-part-field input {
            flex: 1;
            padding: 8px 12px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(201,169,89,0.1);
            border-radius: 8px;
            color: #fff;
        }
        .coat-part-field input:focus {
            outline: none;
            border-color: #c9a959;
        }
        .edit-part-field {
            background: rgba(255,255,255,0.03);
            padding: 10px;
            border-radius: 8px;
            border: 1px solid rgba(201,169,89,0.05);
        }
        .edit-part-field .part-header {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: #8892b0;
            margin-bottom: 2px;
        }
        .edit-part-field .part-header .name {
            color: #fff;
            font-weight: 600;
        }
        .edit-part-field .part-header .done {
            color: #fff;
        }
        .edit-part-field input {
            width: 100%;
            padding: 6px 10px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(201,169,89,0.15);
            border-radius: 6px;
            color: #fff;
            font-size: 13px;
        }
        .edit-part-field .part-info {
            font-size: 10px;
            color: #8892b0;
            margin-top: 2px;
        }
        .edit-part-field .part-info .warning {
            color: #f87171;
        }
        .modal-content-edit {
            max-width: 600px;
            max-height: 90vh;
            overflow-y: auto;
        }
        .btn-edit-save {
            flex: 1;
            padding: 12px;
            background: linear-gradient(135deg, #c9a959, #b89840);
            border: none;
            border-radius: 10px;
            font-weight: 700;
            color: #0a0e1a;
            cursor: pointer;
        }
        .btn-edit-save:hover {
            transform: scale(1.02);
        }
        .btn-edit-cancel {
            flex: 1;
            padding: 12px;
            background: rgba(255,255,255,0.08);
            border: none;
            border-radius: 10px;
            color: #fff;
            cursor: pointer;
        }
        .btn-edit-cancel:hover {
            background: rgba(255,255,255,0.15);
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <a href="/admin/models" style="color:#c9a959; text-decoration:none; margin-right:15px;">🧵 Модели</a>
            <a href="/admin/colors" style="color:#c9a959; text-decoration:none; margin-right:15px;">🎨 Цвета</a>
            <a href="/admin/workers" style="color:#c9a959; text-decoration:none; margin-right:15px;">👥 Сотрудники</a>
            <a href="/admin/shifts" style="color:#c9a959; text-decoration:none; margin-right:15px;">📊 Смены</a>
            <span style="color:#8892b0;"><%= user.fullName %></span>
            <a href="/logout" style="color:#f87171; text-decoration:none;">Выйти</a>
        </div>
    </div>

    <div class="container">
        <h1 class="page-title">👑 Админ панель</h1>

        <div class="stats">
            <div class="stat-card"><span class="stat-icon">📋</span><div class="stat-number"><%= tasks ? tasks.length : 0 %></div><div class="stat-label">Всего заданий</div></div>
            <div class="stat-card"><span class="stat-icon">✅</span><div class="stat-number"><%= tasks ? tasks.filter(t => t.status === 'completed').length : 0 %></div><div class="stat-label">Выполнено</div></div>
            <div class="stat-card"><span class="stat-icon">⏳</span><div class="stat-number"><%= tasks ? tasks.filter(t => t.status === 'pending' || t.status === 'in_progress').length : 0 %></div><div class="stat-label">В работе</div></div>
        </div>

        <!-- ===== ФОРМА СОЗДАНИЯ ===== -->
        <div class="create-task">
            <h2>➕ Создать задание</h2>
            <form action="/api/tasks" method="post" class="form-grid" id="taskForm">
                
                <div style="display:flex; gap:12px; grid-column:1/-1; align-items:center;">
                    <div style="flex:1; min-width:200px;">
                        <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">📋 Модель</label>
                        <select name="modelId_select" id="modelSelect" class="searchable-select" style="width:100%;">
                            <option value="">Выберите модель...</option>
                        </select>
                    </div>
                    <div style="flex:1; min-width:200px; position:relative;">
                        <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">🔍 Быстрый поиск</label>
                        <div class="search-wrapper">
                            <input type="text" id="modelSearch" placeholder="Название или программа..." autocomplete="off" style="width:100%; padding:12px 16px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff; font-size:14px;">
                            <div class="search-results" id="modelResults"></div>
                        </div>
                        <input type="hidden" name="modelId" id="modelId">
                        <div class="selected-value" id="selectedModel" style="margin-top:4px; padding:4px 10px; background:rgba(201,169,89,0.1); border-radius:4px; color:#c9a959; font-size:12px; display:none;">
                            ✅ Выбрано: <span></span>
                        </div>
                    </div>
                </div>
                
                <div id="modelInfo" style="display:none; grid-column:1/-1; background:rgba(255,255,255,0.03); padding:12px 15px; border-radius:10px;">
                    <div style="display:flex; flex-wrap:wrap; gap:10px 20px; font-size:13px; color:#8892b0;">
                        <span>📄 Программа: <strong style="color:#fff;" id="infoProgram">—</strong></span>
                        <span>📏 Размер: <strong style="color:#fff;" id="infoSize">—</strong></span>
                        <span>🔧 Класс: <strong style="color:#fff;" id="infoClass">—</strong></span>
                        <span>🧵 Пряжа: <strong style="color:#fff;" id="infoYarn">—</strong></span>
                        <span>📷 Фото: <strong style="color:#fff;" id="infoImage">—</strong></span>
                        <span>🧥 Тип: <strong style="color:#fff;" id="infoType">—</strong></span>
                    </div>
                </div>

                <div style="display:flex; gap:12px; grid-column:1/-1; align-items:center;">
                    <div style="flex:1; min-width:200px;">
                        <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">🎨 Цвет</label>
                        <select name="colorId_select" id="colorSelect" class="searchable-select" style="width:100%;">
                            <option value="">Выберите цвет...</option>
                        </select>
                    </div>
                    <div style="flex:1; min-width:200px; position:relative;">
                        <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">🔍 Быстрый поиск</label>
                        <div class="search-wrapper">
                            <input type="text" id="colorSearch" placeholder="Название цвета..." autocomplete="off" style="width:100%; padding:12px 16px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff; font-size:14px;">
                            <div class="search-results" id="colorResults"></div>
                        </div>
                        <input type="hidden" name="colorId" id="colorId">
                        <div class="selected-value" id="selectedColor" style="margin-top:4px; padding:4px 10px; background:rgba(201,169,89,0.1); border-radius:4px; color:#c9a959; font-size:12px; display:none;">
                            ✅ Выбрано: <span></span>
                        </div>
                    </div>
                </div>
                
                <div style="grid-column:1/-1; max-width:300px;">
                    <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">🏢 ИП</label>
                    <select name="ip" required class="searchable-select" style="width:100%;">
                        <option value="">Выберите ИП...</option>
                        <option value="ИП Алла">ИП Алла</option>
                        <option value="ИП Заур">ИП Заур</option>
                    </select>
                </div>
                
                <div id="quantityBlock" style="grid-column:1/-1; max-width:200px;">
                    <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">📦 Количество</label>
                    <input type="number" name="planQuantity" id="planQuantity" placeholder="шт." required style="width:100%; padding:12px 16px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff; font-size:14px;">
                </div>

                <div id="coatPartsBlock" style="display:none; grid-column:1/-1; background:rgba(255,255,255,0.03); padding:15px; border-radius:10px; margin-top:5px;">
                    <div style="color:#c9a959; font-weight:600; margin-bottom:10px; font-size:14px;">🧥 Детали кофты (укажите количество для каждой)</div>
                    <div id="coatPartsFields" style="display:grid; grid-template-columns: 1fr; gap:10px;"></div>
                </div>

                <div style="grid-column:1/-1; display:flex; align-items:center; gap:10px; margin-top:5px;">
                    <input type="checkbox" name="isUrgent" id="urgent" style="width:18px; height:18px;">
                    <label for="urgent" style="color:#f87171; font-weight:600; font-size:15px;">🔥 Срочно</label>
                </div>
                
                <button type="submit" class="btn-submit" style="grid-column:1/-1; max-width:200px;">💾 Создать</button>
            </form>
        </div>

        <!-- ПОИСК ПО ТАБЛИЦЕ -->
        <div style="margin-bottom:20px;">
            <input type="text" id="taskSearch" placeholder="🔍 Поиск по заданиям..." style="width:100%; padding:12px 16px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.15); border-radius:10px; color:#fff; font-size:16px;">
            <div style="color:#8892b0; font-size:14px; margin-top:6px;">Найдено: <strong id="searchCount">0</strong></div>
        </div>

        <!-- ТАБЛИЦА ЗАДАНИЙ -->
        <div class="tasks-table">
            <table>
                <thead>
                    <tr>
                        <th>Модель</th>
                        <th>Программа</th>
                        <th>Размер</th>
                        <th>Цвет</th>
                        <th>ИП</th>
                        <th>Кол-во</th>
                        <th>Связано</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody id="tasksBody">
                    <% 
                        function getCoatProgress(coat) {
                            const parts = coat.parts || [];
                            let totalDone = 0;
                            let totalPlan = 0;
                            parts.forEach(part => {
                                const done = part.doneQuantity || 0;
                                totalDone += Math.min(done, part.planQuantity);
                                totalPlan += part.planQuantity;
                            });
                            return { totalDone, totalPlan };
                        }

                        function getPartsString(coat) {
                            const parts = coat.parts || [];
                            return parts.map(p => p.partName || p.Model?.name || 'Деталь').join(', ');
                        }
                    %>
                    <% if (tasks && tasks.length > 0) { %>
                        <% tasks.forEach(task => { 
                            let totalDone = 0;
                            let totalPlan = task.planQuantity;
                            let isCoat = task.isCoat || false;
                            let partsString = '';
                            
                            if (isCoat) {
                                const progress = getCoatProgress(task);
                                totalDone = progress.totalDone;
                                totalPlan = progress.totalPlan;
                                partsString = getPartsString(task);
                            } else {
                                totalDone = task.doneQuantity || 0;
                            }
                            
                            const percent = totalPlan > 0 ? Math.min((totalDone / totalPlan) * 100, 100) : 0;
                            const searchData = [
                                task.Model ? task.Model.name : '',
                                task.Model ? task.Model.program : '',
                                task.Model ? task.Model.size : '',
                                task.Color ? task.Color.name : '',
                                task.ip || '',
                                task.planQuantity || '',
                                totalDone || '',
                                isCoat ? 'кофта' : 'шапка'
                            ].join(' ').toLowerCase();
                        %>
                            <tr class="task-row" data-search="<%= searchData %>">
                                <td>
                                    <%= task.Model ? task.Model.name : '—' %>
                                    <% if (isCoat) { %>
                                        <span style="font-size:10px; color:#c9a959; display:block;">
                                            🧥 Кофта
                                            <span class="coat-parts-info">
                                                (<% partsString.split(', ').forEach((p, i) => { %><span class="part-item"><%= p %></span><% }); %>)
                                            </span>
                                        </span>
                                    <% } %>
                                </td>
                                <td><%= task.Model ? task.Model.program : '—' %></td>
                                <td><%= task.Model ? task.Model.size : '—' %></td>
                                <td><%= task.Color ? task.Color.name : '—' %></td>
                                <td><%= task.ip || '—' %></td>
                                <td><%= totalPlan %></td>
                                <td>
                                    <%= totalDone %>
                                    <% if (totalPlan > 0) { %>
                                        <div class="coat-progress-bar">
                                            <div class="fill" style="width:<%= percent %>%;"></div>
                                        </div>
                                        <span class="coat-progress-text"><%= Math.round(percent) %>%</span>
                                    <% } %>
                                </td>
                                <td><span class="status-badge <%= task.status === 'completed' ? 'status-completed' : 'status-pending' %>"><%= task.status === 'completed' ? '✅ Готов' : '⏳ В работе' %></span></td>
                                <td style="display:flex; gap:5px; flex-wrap:wrap;">
                                    <button onclick="editTask(<%= task.id %>)" style="background:#c9a959; color:#0a0e1a; border:none; padding:4px 10px; border-radius:6px; cursor:pointer;">✏️</button>
                                    <form action="/api/tasks/duplicate/<%= task.id %>" method="post" style="display:inline;">
                                        <button type="submit" style="background:#60a5fa; color:#fff; border:none; padding:4px 10px; border-radius:6px; cursor:pointer;">🔄</button>
                                    </form>
                                    <form action="/api/tasks/delete/<%= task.id %>" method="post" style="display:inline;" onsubmit="return confirm('Удалить задание #<%= task.id %> и все его детали?')">
                                        <button type="submit" style="background:#f87171; color:#fff; border:none; padding:4px 10px; border-radius:6px; cursor:pointer;">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr id="noTasksRow"><td colspan="9" style="text-align:center; color:#475569;">Нет заданий</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- ===== МОДАЛКА РЕДАКТИРОВАНИЯ ===== -->
    <div id="editModal" class="modal">
        <div class="modal-content modal-content-edit">
            <h2>✏️ Редактирование заказа #<span id="editTaskIdDisplay"></span></h2>
            <form id="editForm">
                <input type="hidden" id="editTaskId" name="taskId">
                
                <div style="background:rgba(255,255,255,0.03); padding:12px 15px; border-radius:10px; margin-bottom:15px;">
                    <div style="display:flex; flex-wrap:wrap; gap:8px 20px; font-size:13px; color:#8892b0;">
                        <span>📄 Модель: <strong style="color:#fff;" id="editModelName">—</strong></span>
                        <span>🎨 Цвет: <strong style="color:#fff;" id="editColorName">—</strong></span>
                        <span>🏢 ИП: <strong style="color:#fff;" id="editIp">—</strong></span>
                    </div>
                </div>

                <div style="margin-bottom:15px;">
                    <div style="display:flex; justify-content:space-between; font-size:14px; color:#8892b0; margin-bottom:4px;">
                        <span>📊 Прогресс</span>
                        <span id="editProgressText"><strong style="color:#fff;" id="editDone">0</strong> из <strong style="color:#c9a959;" id="editPlan">0</strong> шт. (<span id="editPercent">0</span>%)</span>
                    </div>
                    <div class="progress-bar" style="height:8px; background:rgba(255,255,255,0.08); border-radius:4px; overflow:hidden;">
                        <div id="editProgressFill" class="progress-fill" style="width:0%; height:100%; background:linear-gradient(90deg, #c9a959, #e8c97a); border-radius:4px; transition:width 0.3s ease;"></div>
                    </div>
                </div>

                <div id="editShapkiFields">
                    <div class="form-group" style="margin-bottom:10px;">
                        <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">📦 Количество (план)</label>
                        <input type="number" id="editQuantity" name="quantity" min="0" required style="width:100%; padding:12px 16px; background:rgba(255,255,255,0.08); border:1px solid rgba(201,169,89,0.15); border-radius:10px; color:#fff; font-size:14px;">
                    </div>
                    <div class="form-group">
                        <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">🔧 Связано (факт)</label>
                        <input type="number" id="editDoneQuantity" name="doneQuantity" min="0" style="width:100%; padding:12px 16px; background:rgba(255,255,255,0.08); border:1px solid rgba(201,169,89,0.15); border-radius:10px; color:#fff; font-size:14px;">
                    </div>
                </div>

                <div id="editCoatFields" style="display:none;">
                    <div style="color:#c9a959; font-weight:600; margin-bottom:8px; font-size:13px;">🧥 Детали кофты</div>
                    <div id="editCoatPartsFields" style="display:grid; grid-template-columns:1fr 1fr; gap:8px;"></div>
                </div>

                <div class="form-group" style="margin-top:15px;">
                    <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">📌 Статус</label>
                    <select id="editStatus" name="status" style="width:100%; padding:12px 16px; background:rgba(255,255,255,0.08); border:1px solid rgba(201,169,89,0.15); border-radius:10px; color:#fff; font-size:14px;">
                        <option value="pending">⏳ В работе</option>
                        <option value="in_progress">🔄 В процессе</option>
                        <option value="completed">✅ Готово</option>
                    </select>
                </div>

                <div class="modal-buttons" style="display:flex; gap:10px; margin-top:20px;">
                    <button type="submit" class="btn-edit-save">💾 Сохранить</button>
                    <button type="button" class="btn-edit-cancel" onclick="closeEditModal()">❌ Отмена</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        // ========================================
        //  ЗАГРУЗКА МОДЕЛЕЙ И ЦВЕТОВ
        // ========================================
        let modelsData = [];
        let colorsData = [];

        async function loadData() {
            try {
                const [models, colors] = await Promise.all([
                    fetch('/api/models').then(r => r.json()),
                    fetch('/api/colors').then(r => r.json())
                ]);
                
                for (const model of models) {
                    if (model.isCoat) {
                        const resp = await fetch(`/api/models/${model.id}`);
                        const fullModel = await resp.json();
                        model.parts = fullModel.parts || [];
                    } else {
                        model.parts = [];
                    }
                }
                
                modelsData = models;
                colorsData = colors;

                const modelSelect = document.getElementById('modelSelect');
                models.forEach(m => {
                    const opt = document.createElement('option');
                    opt.value = m.id;
                    opt.textContent = m.name + ' (' + m.program + ')' + (m.isCoat ? ' 🧥' : '');
                    modelSelect.appendChild(opt);
                });

                const colorSelect = document.getElementById('colorSelect');
                colors.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c.id;
                    opt.textContent = c.name;
                    colorSelect.appendChild(opt);
                });

                const modelInput = document.getElementById('modelSearch');
                const modelResults = document.getElementById('modelResults');

                modelInput.addEventListener('input', function() {
                    const query = this.value.toLowerCase().trim();
                    modelResults.innerHTML = '';
                    if (query.length === 0) {
                        modelResults.style.display = 'none';
                        return;
                    }
                    const filtered = modelsData.filter(m => 
                        m.name.toLowerCase().includes(query) || 
                        m.program.toLowerCase().includes(query)
                    );
                    if (filtered.length === 0) {
                        modelResults.style.display = 'none';
                        return;
                    }
                    filtered.forEach(m => {
                        const div = document.createElement('div');
                        div.className = 'result-item';
                        div.innerHTML = `${m.name} <span class="sub">${m.program}${m.isCoat ? ' 🧥' : ''}</span>`;
                        div.addEventListener('click', function() {
                            selectModel(m);
                        });
                        modelResults.appendChild(div);
                    });
                    modelResults.style.display = 'block';
                });

                const colorInput = document.getElementById('colorSearch');
                const colorResults = document.getElementById('colorResults');

                colorInput.addEventListener('input', function() {
                    const query = this.value.toLowerCase().trim();
                    colorResults.innerHTML = '';
                    if (query.length === 0) {
                        colorResults.style.display = 'none';
                        return;
                    }
                    const filtered = colorsData.filter(c => 
                        c.name.toLowerCase().includes(query)
                    );
                    if (filtered.length === 0) {
                        colorResults.style.display = 'none';
                        return;
                    }
                    filtered.forEach(c => {
                        const div = document.createElement('div');
                        div.className = 'result-item';
                        div.textContent = c.name;
                        div.addEventListener('click', function() {
                            selectColor(c);
                        });
                        colorResults.appendChild(div);
                    });
                    colorResults.style.display = 'block';
                });

                modelSelect.addEventListener('change', function() {
                    const modelId = this.value;
                    if (modelId) {
                        const model = modelsData.find(m => m.id == modelId);
                        if (model) {
                            showModelInfo(model);
                            document.getElementById('modelSearch').value = model.name;
                            document.getElementById('modelId').value = model.id;
                            const selectedDiv = document.getElementById('selectedModel');
                            selectedDiv.querySelector('span').textContent = model.name + ' (' + model.program + ')';
                            selectedDiv.style.display = 'block';
                            updateCoatParts(model);
                        }
                    } else {
                        document.getElementById('modelInfo').style.display = 'none';
                        document.getElementById('modelId').value = '';
                        document.getElementById('selectedModel').style.display = 'none';
                        updateCoatParts(null);
                    }
                });

                colorSelect.addEventListener('change', function() {
                    const colorId = this.value;
                    if (colorId) {
                        const color = colorsData.find(c => c.id == colorId);
                        if (color) {
                            document.getElementById('colorSearch').value = color.name;
                            document.getElementById('colorId').value = color.id;
                            const selectedDiv = document.getElementById('selectedColor');
                            selectedDiv.querySelector('span').textContent = color.name;
                            selectedDiv.style.display = 'block';
                        }
                    } else {
                        document.getElementById('colorId').value = '';
                        document.getElementById('selectedColor').style.display = 'none';
                    }
                });

                document.addEventListener('click', function(e) {
                    if (!e.target.closest('.search-wrapper')) {
                        modelResults.style.display = 'none';
                        colorResults.style.display = 'none';
                    }
                });

            } catch (err) {
                console.error('Ошибка загрузки:', err);
            }
        }

        function showModelInfo(model) {
            const infoDiv = document.getElementById('modelInfo');
            document.getElementById('infoProgram').textContent = model.program || '—';
            document.getElementById('infoSize').textContent = model.size || '—';
            document.getElementById('infoClass').textContent = model.className || '—';
            document.getElementById('infoYarn').textContent = model.yarn || '—';
            document.getElementById('infoImage').textContent = model.image ? '📷 Есть' : '—';
            document.getElementById('infoType').textContent = model.isCoat ? '🧥 Кофта' : '🧢 Обычная';
            infoDiv.style.display = 'block';
        }

        function selectModel(model) {
            document.getElementById('modelSearch').value = model.name;
            document.getElementById('modelId').value = model.id;
            document.getElementById('modelResults').style.display = 'none';
            
            const selectedDiv = document.getElementById('selectedModel');
            selectedDiv.querySelector('span').textContent = model.name + ' (' + model.program + ')';
            selectedDiv.style.display = 'block';

            showModelInfo(model);
            updateCoatParts(model);
            
            const modelSelect = document.getElementById('modelSelect');
            modelSelect.value = model.id;
        }

        function selectColor(color) {
            document.getElementById('colorSearch').value = color.name;
            document.getElementById('colorId').value = color.id;
            document.getElementById('colorResults').style.display = 'none';
            
            const selectedDiv = document.getElementById('selectedColor');
            selectedDiv.querySelector('span').textContent = color.name;
            selectedDiv.style.display = 'block';
            
            const colorSelect = document.getElementById('colorSelect');
            colorSelect.value = color.id;
        }

        function updateCoatParts(model) {
            const coatPartsBlock = document.getElementById('coatPartsBlock');
            const coatPartsFields = document.getElementById('coatPartsFields');
            const quantityBlock = document.getElementById('quantityBlock');
            const planQuantity = document.getElementById('planQuantity');
            
            if (model && model.isCoat && model.parts && model.parts.length > 0) {
                coatPartsBlock.style.display = 'block';
                quantityBlock.style.display = 'none';
                planQuantity.removeAttribute('required');
                
                coatPartsFields.innerHTML = '';
                
                model.parts.forEach(part => {
    const div = document.createElement('div');
    div.className = 'coat-part-field';
    div.style.cssText = 'display:flex; align-items:center; gap:10px;';
    div.innerHTML = `
        <label style="min-width:80px; color:#fff; font-weight:500;">${part.partName}:</label>
        <input type="number" name="part_${part.id}" placeholder="шт." min="0" style="width:100px; padding:6px 10px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:8px; color:#fff; font-size:14px;">
    `;
    coatPartsFields.appendChild(div);
});
            } else {
                coatPartsBlock.style.display = 'none';
                quantityBlock.style.display = 'block';
                planQuantity.setAttribute('required', 'required');
            }
        }

        loadData();

        // ========================================
        //  ПОИСК ПО ТАБЛИЦЕ
        // ========================================
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('taskSearch');
            const rows = document.querySelectorAll('.task-row');
            const noTasksRow = document.getElementById('noTasksRow');
            const searchCount = document.getElementById('searchCount');

            if (rows.length === 0) {
                if (searchCount) searchCount.textContent = '0';
                return;
            }

            searchInput.addEventListener('input', function() {
                const filter = this.value.toLowerCase().trim();
                let visibleCount = 0;

                rows.forEach(row => {
                    const searchData = row.getAttribute('data-search') || '';
                    const isVisible = searchData.includes(filter);
                    row.style.display = isVisible ? '' : 'none';
                    if (isVisible) visibleCount++;
                });

                if (noTasksRow) {
                    noTasksRow.style.display = (visibleCount === 0 && rows.length > 0) ? 'table-row' : 'none';
                }

                if (searchCount) searchCount.textContent = visibleCount;
            });

            if (searchCount) searchCount.textContent = rows.length;
        });

        // ========================================
//  РЕДАКТИРОВАНИЕ ЗАДАНИЯ
// ========================================

async function editTask(taskId) {
    const modal = document.getElementById('editModal');
    document.getElementById('editTaskId').value = taskId;
    document.getElementById('editTaskIdDisplay').textContent = taskId;
    modal.classList.add('active');
    
    try {
        const response = await fetch('/api/tasks/' + taskId + '/edit-data');
        const data = await response.json();
        
        if (!data.success) {
            alert('❌ Ошибка загрузки: ' + (data.error || 'Неизвестная ошибка'));
            return;
        }
        
        const task = data.task;
        const isCoat = task.isCoat || false;
        const parts = task.parts || [];
        
        document.getElementById('editModelName').textContent = task.Model?.name || '—';
        document.getElementById('editColorName').textContent = task.Color?.name || '—';
        document.getElementById('editIp').textContent = task.ip || '—';
        
        let totalDone = data.totalDone || 0;
        let totalPlan = data.totalPlan || task.planQuantity || 0;
        let percent = totalPlan > 0 ? Math.min((totalDone / totalPlan) * 100, 100) : 0;
        
        document.getElementById('editDone').textContent = totalDone;
        document.getElementById('editPlan').textContent = totalPlan;
        document.getElementById('editPercent').textContent = Math.round(percent);
        document.getElementById('editProgressFill').style.width = percent + '%';
        document.getElementById('editProgressText').innerHTML = 
            `<strong style="color: #fff;" id="editDone">${totalDone}</strong> из <strong style="color: #c9a959;" id="editPlan">${totalPlan}</strong> шт. (<span id="editPercent">${Math.round(percent)}</span>%)`;
        
        document.getElementById('editStatus').value = task.status || 'pending';
        
        // ========================================
        //  ПОКАЗЫВАЕМ НУЖНЫЕ ПОЛЯ
        // ========================================
        if (isCoat && parts.length > 0) {
            // === ЭТО КОФТА ===
            document.getElementById('editShapkiFields').style.display = 'none';
            document.getElementById('editCoatFields').style.display = 'block';
            
            // ✅ Убираем required у скрытых полей шапки
            document.getElementById('editQuantity').removeAttribute('required');
            document.getElementById('editDoneQuantity').removeAttribute('required');
            
            // Заполняем детали кофты
            const container = document.getElementById('editCoatPartsFields');
            container.innerHTML = '';
            
            parts.forEach(part => {
                const partDone = part.doneQuantity || 0;
                const partPlan = part.planQuantity || 0;
                
                const div = document.createElement('div');
                div.className = 'edit-part-field';
                div.innerHTML = `
                    <div class="part-header">
                        <span class="name">${part.partName || 'Деталь'}</span>
                        <span>связано: <strong class="done">${partDone}</strong></span>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
                        <div>
                            <label style="font-size:10px; color:#8892b0; display:block;">📦 План</label>
                            <input type="number" name="part_${part.id}_plan" value="${partPlan}" min="0">
                        </div>
                        <div>
                            <label style="font-size:10px; color:#8892b0; display:block;">🔧 Связано</label>
                            <input type="number" name="part_${part.id}_done" value="${partDone}" min="0">
                        </div>
                    </div>
                `;
                container.appendChild(div);
            });
            
        } else {
            // === ЭТО ШАПКА ===
            document.getElementById('editShapkiFields').style.display = 'block';
            document.getElementById('editCoatFields').style.display = 'none';
            
            // ✅ Добавляем required для шапок
            document.getElementById('editQuantity').setAttribute('required', 'required');
            document.getElementById('editDoneQuantity').removeAttribute('required');
            
            document.getElementById('editQuantity').value = task.planQuantity || 0;
            document.getElementById('editDoneQuantity').value = totalDone || 0;
        }
        
    } catch (err) {
        alert('❌ Ошибка загрузки: ' + err.message);
        closeEditModal();
    }
}

function closeEditModal() {
    document.getElementById('editModal').classList.remove('active');
}

        // ========================================
        //  ОБРАБОТЧИК ФОРМЫ РЕДАКТИРОВАНИЯ (С ЛОГАМИ)
        // ========================================

        document.addEventListener('DOMContentLoaded', function() {
            const editForm = document.getElementById('editForm');
            
            editForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                console.log('🔵 Форма отправлена!');
                
                const taskId = document.getElementById('editTaskId').value;
                const status = document.getElementById('editStatus').value;
                const isCoat = document.getElementById('editCoatFields').style.display !== 'none';
                
                console.log('📌 taskId:', taskId);
                console.log('📌 status:', status);
                console.log('📌 isCoat:', isCoat);
                
                let data = { status };
                
                if (isCoat) {
                    const inputs = document.querySelectorAll('#editCoatPartsFields input');
                    const parts = {};
                    inputs.forEach(input => {
                        const name = input.getAttribute('name');
                        if (name) {
                            parts[name] = parseInt(input.value) || 0;
                            console.log('   ' + name + ':', parts[name]);
                        }
                    });
                    data.parts = parts;
                    console.log('📦 Данные кофты:', data);
                } else {
                    data.quantity = parseInt(document.getElementById('editQuantity').value) || 0;
                    data.doneQuantity = parseInt(document.getElementById('editDoneQuantity').value) || 0;
                    console.log('📦 Данные шапки:', data);
                }
                
                console.log('📤 Отправляю на сервер:', JSON.stringify(data));
                
                try {
                    const response = await fetch('/api/tasks/edit/' + taskId, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    
                    console.log('📥 Статус ответа:', response.status);
                    
                    const result = await response.json();
                    console.log('✅ Ответ сервера:', result);
                    
                    if (result.success) {
                        alert('✅ Изменения сохранены!');
                        closeEditModal();
                        location.reload();
                    } else {
                        alert('❌ Ошибка: ' + (result.error || 'Неизвестная ошибка'));
                    }
                } catch (err) {
                    console.error('❌ Ошибка запроса:', err);
                    alert('❌ Ошибка: ' + err.message);
                }
            });
        });
    </script>
</body>
</html>