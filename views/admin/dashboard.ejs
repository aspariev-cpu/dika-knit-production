<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Админ панель</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <a href="/admin/workers" style="color:#c9a959; text-decoration:none; margin-right:15px; font-weight:600;">👥 Сотрудники</a>
            <a href="/admin/shifts" style="color:#c9a959; text-decoration:none; margin-right:15px; font-weight:600;">📊 Смены</a>
            <span style="color:#aaa;"><%= user.fullName %></span>
            <a href="/logout" class="logout-btn">Выйти</a>
        </div>
    </div>

    <div class="container">
        <h1 class="page-title">👑 Админ панель</h1>

        <div class="stats">
            <div class="stat-card">
                <span class="stat-icon">📋</span>
                <div class="stat-number"><%= typeof totalTasks !== 'undefined' ? totalTasks : 0 %></div>
                <div class="stat-label">Всего заданий</div>
            </div>
            <div class="stat-card">
                <span class="stat-icon">✅</span>
                <div class="stat-number"><%= typeof completedTasks !== 'undefined' ? completedTasks : 0 %></div>
                <div class="stat-label">Выполнено</div>
            </div>
            <div class="stat-card">
                <span class="stat-icon">🧶</span>
                <div class="stat-number"><%= typeof totalMade !== 'undefined' ? totalMade : 0 %></div>
                <div class="stat-label">Связано шт.</div>
            </div>
        </div>

        <div class="create-task">
            <h2>➕ Создать задание</h2>
            <form action="/api/tasks" method="post" class="form-grid">
                <input type="text" name="modelName" placeholder="Модель" required>
                <input type="text" name="color" placeholder="Цвет" required>
                <select name="className" required>
                    <option value="">Класс</option>
                    <option value="Stoll">Stoll</option>
                    <option value="5">5</option>
                    <option value="7">7</option>
                    <option value="12">12</option>
                    <option value="14">14</option>
                </select>
                <div class="checkbox-group">
                    <input type="checkbox" name="isUrgent" id="urgent">
                    <label for="urgent">🔥 Срочно</label>
                </div>
                <div class="checkbox-group" style="grid-column: 1/-1;">
                    <input type="checkbox" name="isCoat" id="isCoat" onchange="toggleCoatFields()">
                    <label for="isCoat">🧥 Это кофта (несколько деталей)</label>
                </div>
                
                <div id="singleProgram" class="form-grid" style="grid-column: 1/-1; display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <input type="text" name="programFile" placeholder="Программа (turin.999)">
                    <input type="number" name="planQuantity" placeholder="Количество (шт.)">
                </div>
                
                <div id="coatFields" style="grid-column: 1/-1; display: none; background: rgba(255,255,255,0.03); padding: 20px; border-radius: 12px; border: 1px solid rgba(255,215,0,0.08);">
                    <h3 style="color: #c9a959; margin-bottom: 15px;">🧵 Детали кофты</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 10px;">
                        <div style="color: #888; font-size: 12px;">Название детали</div>
                        <div style="color: #888; font-size: 12px;">Программа</div>
                        <div style="color: #888; font-size: 12px;">Количество</div>
                    </div>
                    <% for (let i = 1; i <= 6; i++) { %>
                        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 8px;">
                            <input type="text" name="coat_name_<%= i %>" placeholder="Деталь <%= i %>" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,215,0,0.08); border-radius:6px; padding:8px 12px; color:#fff;">
                            <input type="text" name="coat_program_<%= i %>" placeholder="program.999" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,215,0,0.08); border-radius:6px; padding:8px 12px; color:#fff;">
                            <input type="number" name="coat_quantity_<%= i %>" placeholder="100" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,215,0,0.08); border-radius:6px; padding:8px 12px; color:#fff;">
                        </div>
                    <% } %>
                </div>
                
                <button type="submit" class="btn-submit" style="grid-column: 1/-1;">Создать</button>
            </form>
        </div>

        <div class="tasks-table">
            <% if (typeof tasks !== 'undefined' && tasks && tasks.length > 0) { %>
            <table>
                <thead>
                    <tr>
                        <th>Модель</th>
                        <th>Цвет</th>
                        <th>Класс</th>
                        <th>Программы</th>
                        <th>Прогресс</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% tasks.forEach(function(task) {
                        let totalDone = 0;
                        let totalPlan = 0;
                        let programsList = [];
                        if (task.programs) {
                            task.programs.forEach(function(p) {
                                totalDone += p.doneQuantity;
                                totalPlan += p.planQuantity;
                                programsList.push(p.name + ' (' + p.doneQuantity + '/' + p.planQuantity + ')');
                            });
                        }
                        let percent = totalPlan > 0 ? Math.min((totalDone / totalPlan) * 100, 100) : 0;
                    %>
                    <tr>
                        <td><%= task.isUrgent ? '🔥 ' : '' %><%= task.modelName %></td>
                        <td><span style="display:inline-block; width:12px; height:12px; border-radius:50%; background:<%= task.color %>;"></span> <%= task.color %></td>
                        <td><%= task.className %></td>
                        <td style="font-size:12px;">
                            <%= task.isCoat ? programsList.join('<br>') : (task.programs && task.programs.length > 0 ? task.programs[0].programFile : '—') %>
                        </td>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div class="progress-bar" style="width:80px;">
                                    <div class="progress-fill" style="width:<%= percent %>%;"></div>
                                </div>
                                <span style="font-size:12px; color:#aaa;"><%= Math.round(percent) %>%</span>
                            </div>
                            <div style="font-size:11px; color:#666;"><%= totalDone %>/<%= totalPlan %> шт.</div>
                        </td>
                        <td>
                            <span class="status-badge <%= task.status === 'completed' ? 'status-completed' : 'status-pending' %>">
                                <% if (task.status === 'completed') { %>
                                    ✅ Готов
                                <% } else { %>
                                    ⏳ В работе
                                <% } %>
                            </span>
                        </td>
                        <td style="display:flex; gap:5px; flex-wrap:wrap;">
                            <a href="/admin/tasks/edit/<%= task.id %>" class="btn btn-secondary btn-sm" style="padding:4px 10px; font-size:11px; text-decoration:none; background:rgba(255,255,255,0.08); border-radius:6px; color:#fff;">✏️</a>
                            <% if (task.status === 'completed') { %>
                                <form action="/api/tasks/restore/<%= task.id %>" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-secondary btn-sm" style="padding:4px 10px; font-size:11px;">↩️ Вернуть</button>
                                </form>
                            <% } %>
                            <form action="/api/tasks/duplicate/<%= task.id %>" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-secondary btn-sm" style="padding:4px 10px; font-size:11px;">🔄 Дублировать</button>
                            </form>
                            <form action="/api/tasks/delete/<%= task.id %>" method="post" style="display:inline;" onsubmit="return confirm('Удалить задание?')">
                                <button type="submit" class="btn btn-danger btn-sm" style="padding:4px 10px; font-size:11px;">🗑️</button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } else { %>
                <div class="empty-state">
                    <span class="empty-icon">📭</span>
                    <p style="font-size:18px; color:#888;">Нет активных заданий</p>
                    <p style="color:#555; margin-top:10px;">Создайте первое задание выше</p>
                </div>
            <% } %>
        </div>
    </div>

    <script>
    function toggleCoatFields() {
        const isCoat = document.getElementById('isCoat').checked;
        document.getElementById('singleProgram').style.display = isCoat ? 'none' : 'grid';
        document.getElementById('coatFields').style.display = isCoat ? 'block' : 'none';
    }
    </script>
</body>
</html>
