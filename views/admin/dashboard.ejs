<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Админ</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <a href="/admin/models" style="color:#c9a959; text-decoration:none; margin-right:15px;">🧵 Модели</a>
            <a href="/admin/colors" style="color:#c9a959; text-decoration:none; margin-right:15px;">🎨 Цвета</a>
            <a href="/admin/workers" style="color:#c9a959; text-decoration:none; margin-right:15px;">👥 Сотрудники</a>
            <a href="/admin/shifts" style="color:#c9a959; text-decoration:none; margin-right:15px;">📊 Смены</a>
            <span style="color:#8892b0;"><%= user.fullName %></span>
            <a href="/logout" style="color:#f87171; text-decoration:none;">Выйти</a>
        </div>
    </div>

    <div class="container">
        <h1 class="page-title">👑 Админ панель</h1>

        <div class="stats">
            <div class="stat-card"><span class="stat-icon">📋</span><div class="stat-number"><%= tasks ? tasks.length : 0 %></div><div class="stat-label">Всего заданий</div></div>
            <div class="stat-card"><span class="stat-icon">✅</span><div class="stat-number"><%= tasks ? tasks.filter(t => t.status === 'completed').length : 0 %></div><div class="stat-label">Выполнено</div></div>
            <div class="stat-card"><span class="stat-icon">⏳</span><div class="stat-number"><%= tasks ? tasks.filter(t => t.status === 'pending' || t.status === 'in_progress').length : 0 %></div><div class="stat-label">В работе</div></div>
        </div>

        <div class="create-task">
            <h2>➕ Создать задание</h2>
            <form action="/api/tasks" method="post" class="form-grid">
                <div class="form-group">
                    <label>Модель</label>
                    <select name="modelId" id="modelSelect" required>
                        <option value="">Выберите модель...</option>
                    </select>
                </div>
                
                <div class="form-group" id="modelInfo" style="display:none; grid-column: 1/-1; background:rgba(255,255,255,0.03); padding:15px; border-radius:10px;">
                    <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:10px;">
                        <div><span style="color:#8892b0;">Программа:</span> <span id="infoProgram">—</span></div>
                        <div><span style="color:#8892b0;">Размер:</span> <span id="infoSize">—</span></div>
                        <div><span style="color:#8892b0;">Класс:</span> <span id="infoClass">—</span></div>
                        <div><span style="color:#8892b0;">Пряжа:</span> <span id="infoYarn">—</span></div>
                        <div style="grid-column: 1/-1;"><span style="color:#8892b0;">Фото:</span> <span id="infoImage">—</span></div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Цвет</label>
                    <select name="colorId" id="colorSelect" required>
                        <option value="">Выберите цвет...</option>
                    </select>
                </div>
                
                <!-- ✅ НОВЫЙ БЛОК: ВЫБОР ИП -->
                <div class="form-group">
                    <label>ИП</label>
                    <select name="ip" required>
                        <option value="">Выберите ИП...</option>
                        <option value="ИП Алла">ИП Алла</option>
                        <option value="ИП Заур">ИП Заур</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label>Количество</label>
                    <input type="number" name="planQuantity" placeholder="шт." required>
                </div>
                <div class="form-group" style="flex-direction:row; align-items:center; gap:10px;">
                    <input type="checkbox" name="isUrgent" id="urgent">
                    <label for="urgent" style="color:#f87171; font-weight:600;">🔥 Срочно</label>
                </div>
                <button type="submit" class="btn-submit">Создать</button>
            </form>
        </div>

        <div class="tasks-table">
            <table>
                <thead>
                    <tr>
                        <th>Модель</th>
                        <th>Программа</th>
                        <th>Размер</th>
                        <th>Цвет</th>
                        <th>ИП</th>
                        <th>Кол-во</th>
                        <th>Связано</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (tasks && tasks.length > 0) { %>
                        <% tasks.forEach(task => { 
                            const totalDone = task.operations ? task.operations.reduce((sum, op) => sum + op.quantity, 0) : 0;
                        %>
                            <tr>
                                <td><%= task.Model ? task.Model.name : '—' %></td>
                                <td><%= task.Model ? task.Model.program : '—' %></td>
                                <td><%= task.Model ? task.Model.size : '—' %></td>
                                <td><%= task.Color ? task.Color.name : '—' %></td>
                                <td><%= task.ip || '—' %></td>
                                <td><%= task.planQuantity %></td>
                                <td><%= totalDone %></td>
                                <td><span class="status-badge <%= task.status === 'completed' ? 'status-completed' : 'status-pending' %>"><%= task.status === 'completed' ? '✅ Готов' : '⏳ В работе' %></span></td>
                                <td style="display:flex; gap:5px; flex-wrap:wrap;">
                                    <button onclick="editTask(<%= task.id %>)" style="background:#c9a959; color:#0a0e1a; border:none; padding:4px 10px; border-radius:6px; cursor:pointer;">✏️</button>
                                    <form action="/api/tasks/duplicate/<%= task.id %>" method="post" style="display:inline;">
                                        <button type="submit" style="background:#60a5fa; color:#fff; border:none; padding:4px 10px; border-radius:6px; cursor:pointer;">🔄</button>
                                    </form>
                                    <form action="/api/tasks/delete/<%= task.id %>" method="post" style="display:inline;" onsubmit="return confirm('Удалить задание #<%= task.id %>?')">
                                        <button type="submit" style="background:#f87171; color:#fff; border:none; padding:4px 10px; border-radius:6px; cursor:pointer;">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="9" style="text-align:center; color:#475569;">Нет заданий</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <div id="editModal" class="modal">
        <div class="modal-content">
            <h2>✏️ Редактировать количество</h2>
            <form id="editForm">
                <input type="hidden" id="editTaskId" name="taskId">
                <div class="form-group">
                    <label>Новое количество</label>
                    <input type="number" id="editQuantity" name="quantity" min="0" required style="width:100%; padding:12px 16px; background:rgba(255,255,255,0.08); border:1px solid rgba(201,169,89,0.15); border-radius:10px; color:#fff;">
                </div>
                <div class="modal-buttons" style="display:flex; gap:10px; margin-top:15px;">
                    <button type="submit" class="btn btn-primary" style="flex:1;">💾 Сохранить</button>
                    <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Отмена</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        async function loadData() {
            try {
                const [models, colors] = await Promise.all([
                    fetch('/api/models').then(r => r.json()),
                    fetch('/api/colors').then(r => r.json())
                ]);

                const modelSelect = document.getElementById('modelSelect');
                models.forEach(m => {
                    const opt = document.createElement('option');
                    opt.value = m.id;
                    opt.textContent = m.name;
                    modelSelect.appendChild(opt);
                });

                const colorSelect = document.getElementById('colorSelect');
                colors.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c.id;
                    opt.textContent = c.name;
                    colorSelect.appendChild(opt);
                });

                modelSelect.addEventListener('change', function() {
                    const modelId = this.value;
                    const infoDiv = document.getElementById('modelInfo');
                    if (modelId) {
                        const model = models.find(m => m.id == modelId);
                        if (model) {
                            document.getElementById('infoProgram').textContent = model.program || '—';
                            document.getElementById('infoSize').textContent = model.size || '—';
                            document.getElementById('infoClass').textContent = model.className || '—';
                            document.getElementById('infoYarn').textContent = model.yarn || '—';
                            document.getElementById('infoImage').textContent = model.image ? '📷 Есть' : '—';
                            infoDiv.style.display = 'block';
                        }
                    } else {
                        infoDiv.style.display = 'none';
                    }
                });
            } catch (err) {
                console.error('Ошибка загрузки:', err);
            }
        }
        loadData();

        function editTask(taskId) {
            const modal = document.getElementById('editModal');
            document.getElementById('editTaskId').value = taskId;
            document.getElementById('editQuantity').value = '';
            modal.classList.add('active');
        }

        function closeEditModal() {
            document.getElementById('editModal').classList.remove('active');
        }

        document.getElementById('editForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const taskId = document.getElementById('editTaskId').value;
            const quantity = document.getElementById('editQuantity').value;
            try {
                const response = await fetch('/api/tasks/edit/' + taskId, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ quantity: parseInt(quantity) })
                });
                if (response.ok) {
                    alert('✅ Количество обновлено');
                    closeEditModal();
                    location.reload();
                } else {
                    alert('❌ Ошибка');
                }
            } catch (err) {
                alert('❌ Ошибка: ' + err.message);
            }
        });

        window.onclick = function(event) {
            const modal = document.getElementById('editModal');
            if (event.target === modal) {
                closeEditModal();
            }
        };
    </script>
</body>
</html>