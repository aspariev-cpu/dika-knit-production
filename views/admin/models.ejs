<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Модели</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <a href="/admin" style="color:#c9a959; text-decoration:none; margin-right:15px;">← Назад</a>
            <span style="color:#8892b0;"><%= user.fullName %></span>
            <a href="/logout" style="color:#f87171; text-decoration:none;">Выйти</a>
        </div>
    </div>

    <div class="container">
        <h1 class="page-title">🧵 Модели</h1>

        <div class="create-task">
            <h2>➕ Добавить модель</h2>
            <form action="/api/models" method="post" class="form-grid" id="modelForm">
                <input type="text" name="name" placeholder="Название модели (Кофта Поло)" required>
                <input type="text" name="program" placeholder="Программа (polka.999)" required>
                <input type="text" name="size" placeholder="Размер (L)" required>
                <select name="className" required>
                    <option value="">Класс</option>
                    <option value="Stoll">Stoll</option>
                    <option value="5">5</option>
                    <option value="7">7</option>
                    <option value="12">12</option>
                    <option value="14">14</option>
                </select>
                <input type="text" name="yarn" placeholder="Пряжа (Alize 100% хлопок)" required>
                
                <div style="grid-column: 1/-1;">
                    <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">Фото модели (Ctrl+V)</label>
                    <textarea name="image" id="imageInput" placeholder="Вставьте фото сюда (Ctrl+V)" style="width:100%; min-height:80px; padding:12px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff; font-family:inherit;"></textarea>
                    <div id="imagePreview" style="margin-top:10px; max-width:150px; display:none;">
                        <img id="previewImg" src="" alt="Предпросмотр" style="max-width:100%; border-radius:8px;">
                    </div>
                </div>
                
                <div style="display:flex; align-items:center; gap:10px; grid-column: 1/-1;">
                    <input type="checkbox" name="isCoat" id="isCoat" onchange="toggleCoatParts()">
                    <label for="isCoat" style="font-weight:600;">🧥 Это кофта (несколько деталей)</label>
                </div>

                <div id="coatParts" style="display:none; grid-column: 1/-1; background:rgba(255,255,255,0.03); padding:20px; border-radius:10px; margin-top:10px;">
                    <h3 style="color:#c9a959; margin-bottom:15px;">🧵 Детали кофты</h3>
                    <div style="display:grid; grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr; gap:8px; margin-bottom:10px; align-items:center;">
                        <div style="color:#8892b0; font-size:11px;">Название</div>
                        <div style="color:#8892b0; font-size:11px;">Программа</div>
                        <div style="color:#8892b0; font-size:11px;">Размер</div>
                        <div style="color:#8892b0; font-size:11px;">Класс</div>
                        <div style="color:#8892b0; font-size:11px;">Пряжа</div>
                        <div style="color:#8892b0; font-size:11px;">Фото (Ctrl+V)</div>
                    </div>
                    <% const partNames = ['Полка', 'Спинка', 'Рукава', 'Воротник', 'Бейка']; %>
                    <% partNames.forEach((part, index) => { %>
                        <div style="display:grid; grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr; gap:8px; margin-bottom:8px; align-items:center;">
                            <input type="text" name="part_name_<%= index %>" value="<%= part %>" readonly style="background:rgba(255,255,255,0.03); padding:6px 8px; border-radius:6px; color:#fff; border:1px solid rgba(255,255,255,0.05);">
                            <input type="text" name="part_program_<%= index %>" placeholder="program.999" style="padding:6px 8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff;">
                            <input type="text" name="part_size_<%= index %>" placeholder="L" style="padding:6px 8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff;">
                            <select name="part_class_<%= index %>" style="padding:6px 8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff;">
                                <option value="">Класс</option>
                                <option value="Stoll">Stoll</option>
                                <option value="5">5</option>
                                <option value="7">7</option>
                                <option value="12">12</option>
                                <option value="14">14</option>
                            </select>
                            <input type="text" name="part_yarn_<%= index %>" placeholder="Пряжа" style="padding:6px 8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff;">
                            <textarea name="part_image_<%= index %>" placeholder="Вставьте фото" style="min-height:40px; padding:6px 8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff; font-family:inherit;"></textarea>
                        </div>
                    <% }); %>
                    <div style="color:#8892b0; font-size:12px; margin-top:10px;">💡 Заполните только те детали, которые нужны. Остальные будут проигнорированы.</div>
                </div>

                <button type="submit" class="btn-submit" style="grid-column: 1/-1;">Добавить</button>
            </form>
        </div>

        <div class="tasks-table">
            <table>
                <thead><tr><th>Модель</th><th>Программа</th><th>Размер</th><th>Класс</th><th>Пряжа</th><th>Кофта</th><th>Фото</th><th>Детали</th><th>Действия</th></tr></thead>
                <tbody>
                    <% if (models && models.length > 0) { %>
                        <% models.forEach(model => { %>
                            <tr>
                                <td><strong><%= model.name %></strong></td>
                                <td><%= model.program %></td>
                                <td><%= model.size %></td>
                                <td><%= model.className %></td>
                                <td><%= model.yarn %></td>
                                <td><%= model.isCoat ? '✅' : '—' %></td>
                                <td><%= model.image ? '📷' : '—' %></td>
                                <td style="font-size:11px;">
                                    <% if (model.parts && model.parts.length > 0) { %>
                                        <%= model.parts.map(p => p.partName).join(', ') %>
                                    <% } else { %>
                                        —
                                    <% } %>
                                </td>
                                <td>
                                    <form action="/api/models/delete/<%= model.id %>" method="post" style="display:inline;" onsubmit="return confirm('Удалить модель?')">
                                        <button type="submit" style="background:#f87171; color:#fff; border:none; padding:4px 12px; border-radius:6px; cursor:pointer;">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="9" style="text-align:center; color:#475569;">Нет моделей</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        function toggleCoatParts() {
            const checked = document.getElementById('isCoat').checked;
            document.getElementById('coatParts').style.display = checked ? 'block' : 'none';
        }

        document.getElementById('imageInput').addEventListener('paste', function(e) {
            const items = e.clipboardData.items;
            for (let item of items) {
                if (item.type.startsWith('image/')) {
                    const file = item.getAsFile();
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const preview = document.getElementById('imagePreview');
                        const img = document.getElementById('previewImg');
                        img.src = event.target.result;
                        preview.style.display = 'block';
                        document.getElementById('imageInput').value = event.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            }
        });
    </script>
</body>
</html>