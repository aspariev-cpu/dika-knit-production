<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Модели</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <a href="/admin" style="color:#c9a959; text-decoration:none; margin-right:15px;">← Назад</a>
            <span style="color:#8892b0;"><%= user.fullName %></span>
            <a href="/logout" style="color:#f87171; text-decoration:none;">Выйти</a>
        </div>
    </div>

    <div class="container">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
            <h1 class="page-title" style="margin-bottom:0;">📦 Модели</h1>
            <a href="/admin/models/export" class="btn-submit" style="padding:6px 16px; background:#4ade80; color:#0a0e1a; text-decoration:none; border-radius:8px; display:inline-block; font-weight:600; font-size:14px;">
                📥 Excel
            </a>
        </div>

        <div class="create-task">
            <h2>➕ Добавить модель</h2>
            <form action="/api/models" method="post" class="form-grid" id="modelForm">
                <input type="text" name="name" placeholder="Название модели (Кофта Поло)" required>
                <input type="text" name="program" placeholder="Программа (polka.999)" required>
                <input type="text" name="size" placeholder="Размер (L)" required>
                <select name="className" required>
                    <option value="">Класс</option>
                    <option value="Stoll">Stoll</option>
                    <option value="5">5</option>
                    <option value="7">7</option>
                    <option value="12">12</option>
                    <option value="14">14</option>
                </select>
                
                <input type="text" name="yarn" id="yarnInput" placeholder="Пряжа (Alize 100% хлопок)" required>
                
                <div style="grid-column: 1/-1;">
                    <label style="color:#8892b0; font-size:12px; display:block; margin-bottom:4px;">Фото модели (Ctrl+V)</label>
                    <textarea name="image" id="imageInput" placeholder="Вставьте фото сюда (Ctrl+V)" style="width:100%; min-height:80px; padding:12px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff; font-family:inherit;"></textarea>
                    <div id="imagePreview" style="margin-top:10px; max-width:150px; display:none;">
                        <img id="previewImg" src="" alt="Предпросмотр" style="max-width:100%; border-radius:8px;">
                    </div>
                </div>
                
                <div style="display:flex; align-items:center; gap:10px; grid-column: 1/-1;">
                    <input type="checkbox" name="isCoat" id="isCoat" onchange="toggleCoatParts()">
                    <label for="isCoat" style="font-weight:600;">🧥 Это кофта (несколько деталей)</label>
                </div>

                <!-- БЛОК ДЕТАЛЕЙ КОФТЫ -->
                <div id="coatParts" style="display:none; grid-column: 1/-1; background:rgba(255,255,255,0.03); padding:20px; border-radius:10px; margin-top:10px;">
                    <h3 style="color:#c9a959; margin-bottom:15px;">🧵 Детали кофты</h3>
                    <div style="display:grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap:8px; margin-bottom:10px; align-items:center;">
                        <div style="color:#8892b0; font-size:11px;">Название</div>
                        <div style="color:#8892b0; font-size:11px;">Программа</div>
                        <div style="color:#8892b0; font-size:11px;">Пряжа</div>
                        <div style="color:#8892b0; font-size:11px;">Фото (Ctrl+V)</div>
                    </div>
                    <% const partNames = ['Полка', 'Спинка', 'Рукава', 'Воротник', 'Бейка']; %>
                    <% partNames.forEach((part, index) => { %>
                        <div style="display:grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap:8px; margin-bottom:8px; align-items:center;">
                            <input type="text" name="part_name_<%= index %>" value="<%= part %>" readonly style="background:rgba(255,255,255,0.03); padding:6px 8px; border-radius:6px; color:#fff; border:1px solid rgba(255,255,255,0.05);">
                            <input type="text" name="part_program_<%= index %>" placeholder="program.999" style="padding:6px 8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff;">
                            <input type="text" name="part_yarn_<%= index %>" placeholder="Пряжа" style="padding:6px 8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff;">
                            <textarea name="part_image_<%= index %>" class="part-image-input" placeholder="Вставьте фото (Ctrl+V)" style="min-height:40px; padding:6px 8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff; font-family:inherit;"></textarea>
                        </div>
                        <div id="partPreview_<%= index %>" style="display:none; margin-top:5px; margin-bottom:10px; grid-column:1/-1;">
                            <img id="partPreviewImg_<%= index %>" src="" alt="Предпросмотр детали" style="max-width:150px; border-radius:8px; border:1px solid rgba(201,169,89,0.2);">
                        </div>
                    <% }); %>
                    <div style="color:#8892b0; font-size:12px; margin-top:10px;">💡 Заполните только те детали, которые нужны. Остальные будут проигнорированы.</div>
                </div>

                <button type="submit" class="btn-submit" style="grid-column: 1/-1;">Добавить</button>
            </form>
        </div>

        <!-- ТАБЛИЦА МОДЕЛЕЙ -->
        <div class="tasks-table">
            <table>
                <thead><tr>
                    <th>Модель</th>
                    <th>Программа</th>
                    <th>Размер</th>
                    <th>Класс</th>
                    <th>Пряжа</th>
                    <th>Кофта</th>
                    <th>Фото</th>
                    <th>Детали</th>
                    <th>Действия</th>
                </tr></thead>
                <tbody>
                    <% if (models && models.length > 0) { %>
                        <% models.forEach(model => { %>
                            <tr>
                                <td><strong><%= model.name %></strong></td>
                                <td><%= model.program %></td>
                                <td><%= model.size %></td>
                                <td><%= model.className %></td>
                                <td><%= model.yarn %></td>
                                <td><%= model.isCoat ? '✅' : '—' %></td>
                                <td><%= model.image ? '📷' : '—' %></td>
                                <td style="font-size:11px;">
                                    <% if (model.parts && model.parts.length > 0) { %>
                                        <%= model.parts.map(p => p.partName).join(', ') %>
                                    <% } else { %>
                                        —
                                    <% } %>
                                </td>
                                <td>
                                    <button onclick="openEditModal(<%= model.id %>)" class="btn btn-secondary" style="padding:4px 12px; background:rgba(201,169,89,0.2); border:none; border-radius:6px; color:#c9a959; cursor:pointer; margin-right:5px;">
                                        ✏️ Изменить
                                    </button>
                                    
                                    <form action="/api/models/delete/<%= model.id %>" method="post" style="display:inline;" onsubmit="return confirm('Удалить модель?')">
                                        <button type="submit" style="background:#f87171; color:#fff; border:none; padding:4px 12px; border-radius:6px; cursor:pointer;">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="9" style="text-align:center; color:#475569;">Нет моделей</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- ======================================== -->
    <!-- МОДАЛЬНОЕ ОКНО РЕДАКТИРОВАНИЯ МОДЕЛИ      -->
    <!-- ======================================== -->
    <div id="editModal" class="modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.7); z-index:1000; align-items:center; justify-content:center;">
        <div style="background:#1a1f36; padding:30px; border-radius:16px; max-width:800px; width:95%; max-height:90vh; overflow-y:auto; border:1px solid rgba(201,169,89,0.2);">
            <h2 style="color:#c9a959; margin-bottom:20px;">✏️ Редактировать модель</h2>
            <form id="editForm" action="#" method="post" style="display:grid; grid-template-columns:1fr 1fr; gap:15px;">
                <input type="hidden" name="_method" value="PUT">
                
                <div class="form-group" style="grid-column:1/3;">
                    <label style="color:#8892b0; font-size:12px;">Название модели</label>
                    <input type="text" name="name" id="editName" required style="width:100%; padding:12px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff;">
                </div>
                
                <div class="form-group">
                    <label style="color:#8892b0; font-size:12px;">Программа</label>
                    <input type="text" name="program" id="editProgram" required style="width:100%; padding:12px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff;">
                </div>
                
                <div class="form-group">
                    <label style="color:#8892b0; font-size:12px;">Размер</label>
                    <input type="text" name="size" id="editSize" required style="width:100%; padding:12px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff;">
                </div>
                
                <div class="form-group">
                    <label style="color:#8892b0; font-size:12px;">Класс</label>
                    <select name="className" id="editClass" required style="width:100%; padding:12px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff;">
                        <option value="Stoll">Stoll</option>
                        <option value="5">5</option>
                        <option value="7">7</option>
                        <option value="12">12</option>
                        <option value="14">14</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label style="color:#8892b0; font-size:12px;">Пряжа</label>
                    <input type="text" name="yarn" id="editYarn" required style="width:100%; padding:12px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff;">
                </div>
                
                <!-- ✅ ИСПРАВЛЕНО: ТЕПЕРЬ ТЕКСТАРЕА ДЛЯ ВСТАВКИ ФОТО -->
                <div class="form-group" style="grid-column:1/3;">
                    <label style="color:#8892b0; font-size:12px;">Фото модели (Ctrl+V)</label>
                    <textarea name="image" id="editImage" placeholder="Вставьте фото сюда (Ctrl+V)" style="width:100%; min-height:80px; padding:12px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff; font-family:inherit;"></textarea>
                    <div id="editImagePreview" style="margin-top:10px; max-width:150px; display:none;">
                        <img id="editPreviewImg" src="" alt="Предпросмотр" style="max-width:100%; border-radius:8px;">
                    </div>
                </div>
                
                <div class="form-group" style="grid-column:1/3; display:flex; align-items:center; gap:10px;">
                    <input type="checkbox" name="isCoat" id="editIsCoat" style="transform:scale(1.2);">
                    <label for="editIsCoat" style="font-weight:600; color:#fff;">🧥 Это кофта</label>
                </div>
                
                <!-- Блок деталей (для кофт) -->
                <div id="editPartsContainer" style="grid-column:1/3; display:none;">
                    <h3 style="color:#c9a959; margin-top:15px;">🧵 Детали кофты</h3>
                    <div id="editPartsFields">
                        <!-- Сюда динамически добавляются поля -->
                    </div>
                </div>
                
                <div style="grid-column:1/3; display:flex; gap:10px; margin-top:20px;">
                    <button type="submit" class="btn btn-primary" style="padding:12px 30px; background:linear-gradient(135deg, #c9a959, #b89840); border:none; border-radius:10px; font-weight:700; color:#0a0e1a; cursor:pointer;">💾 Сохранить</button>
                    <button type="button" onclick="closeEditModal()" class="btn btn-secondary" style="padding:12px 30px; background:rgba(255,255,255,0.08); border:none; border-radius:10px; color:#fff; cursor:pointer;">❌ Отмена</button>
                </div>
            </form>
        </div>
    </div>

    <!-- ======================================== -->
    <!-- СКРИПТЫ                                   -->
    <!-- ======================================== -->
    <script>
        // ---------- ВСТАВКА ФОТО (Ctrl+V) ДЛЯ ОСНОВНОЙ МОДЕЛИ (СОЗДАНИЕ) ----------
        document.getElementById('imageInput').addEventListener('paste', function(e) {
            const items = e.clipboardData.items;
            for (let item of items) {
                if (item.type.startsWith('image/')) {
                    const file = item.getAsFile();
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const preview = document.getElementById('imagePreview');
                        const img = document.getElementById('previewImg');
                        img.src = event.target.result;
                        preview.style.display = 'block';
                        document.getElementById('imageInput').value = event.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            }
        });

        // ---------- ВСТАВКА ФОТО (Ctrl+V) ДЛЯ РЕДАКТИРОВАНИЯ МОДЕЛИ ----------
        document.getElementById('editImage').addEventListener('paste', function(e) {
            const items = e.clipboardData.items;
            for (let item of items) {
                if (item.type.startsWith('image/')) {
                    const file = item.getAsFile();
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const preview = document.getElementById('editImagePreview');
                        const img = document.getElementById('editPreviewImg');
                        img.src = event.target.result;
                        preview.style.display = 'block';
                        document.getElementById('editImage').value = event.target.result;
                        showNotification('✅ Фото модели вставлено!', 'success');
                    };
                    reader.readAsDataURL(file);
                }
            }
        });

        // ---------- ВСТАВКА ФОТО ДЛЯ ДЕТАЛЕЙ КОФТЫ (СОЗДАНИЕ) ----------
        document.querySelectorAll('.part-image-input').forEach((textarea, index) => {
            textarea.addEventListener('paste', function(e) {
                const items = e.clipboardData.items;
                let imageFound = false;
                
                for (let item of items) {
                    if (item.type.startsWith('image/')) {
                        const file = item.getAsFile();
                        const reader = new FileReader();
                        const self = this;
                        
                        reader.onload = function(event) {
                            self.value = event.target.result;
                            const previewDiv = document.getElementById('partPreview_' + index);
                            const previewImg = document.getElementById('partPreviewImg_' + index);
                            if (previewDiv && previewImg) {
                                previewImg.src = event.target.result;
                                previewDiv.style.display = 'block';
                            }
                            showNotification('✅ Фото детали вставлено!', 'success');
                        };
                        
                        reader.readAsDataURL(file);
                        imageFound = true;
                        e.preventDefault();
                        break;
                    }
                }
                
                if (!imageFound) {
                    showNotification('❌ Вставьте изображение (Ctrl+V)', 'error');
                }
            });
        });

        // ---------- ФУНКЦИЯ ДЛЯ УВЕДОМЛЕНИЙ ----------
        function showNotification(message, type) {
            const colors = { success: '#4ade80', error: '#f87171', info: '#c9a959' };
            const oldNotifications = document.querySelectorAll('.custom-notification');
            oldNotifications.forEach(el => el.remove());
            
            const notification = document.createElement('div');
            notification.className = 'custom-notification';
            notification.style.cssText = `
                position: fixed;
                top: 80px;
                right: 20px;
                background: rgba(255,255,255,0.08);
                color: #fff;
                padding: 14px 20px;
                border-radius: 12px;
                border-left: 4px solid ${colors[type] || colors.info};
                box-shadow: 0 10px 30px rgba(0,0,0,0.4);
                font-size: 14px;
                font-weight: 500;
                animation: slideInRight 0.4s ease;
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255,255,255,0.05);
                z-index: 9999;
                max-width: 350px;
            `;
            notification.textContent = message;
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.style.animation = 'slideOutRight 0.4s ease';
                setTimeout(() => notification.remove(), 400);
            }, 3000);
        }

        // ---------- СКРЫВАЕМ ПОЛЕ "ПРЯЖА" ДЛЯ КОФТ ----------
        document.getElementById('isCoat').addEventListener('change', function() {
            const yarnInput = document.getElementById('yarnInput');
            if (this.checked) {
                yarnInput.style.display = 'none';
                yarnInput.removeAttribute('required');
            } else {
                yarnInput.style.display = 'block';
                yarnInput.setAttribute('required', 'required');
            }
        });

        function toggleCoatParts() {
            const checked = document.getElementById('isCoat').checked;
            document.getElementById('coatParts').style.display = checked ? 'block' : 'none';
        }

        // ---------- РЕДАКТИРОВАНИЕ МОДЕЛИ ----------
        let editModelId = null;

        function openEditModal(modelId) {
            editModelId = modelId;
            const modal = document.getElementById('editModal');
            
            fetch('/api/models/' + modelId)
                .then(res => res.json())
                .then(model => {
                    document.getElementById('editName').value = model.name || '';
                    document.getElementById('editProgram').value = model.program || '';
                    document.getElementById('editSize').value = model.size || '';
                    document.getElementById('editClass').value = model.className || '';
                    document.getElementById('editYarn').value = model.yarn || '';
                    document.getElementById('editImage').value = model.image || '';
                    document.getElementById('editIsCoat').checked = model.isCoat || false;
                    
                    // Показываем превью если есть фото
                    if (model.image) {
                        const preview = document.getElementById('editImagePreview');
                        const img = document.getElementById('editPreviewImg');
                        img.src = model.image;
                        preview.style.display = 'block';
                    }
                    
                    const form = document.getElementById('editForm');
                    form.action = '/api/models/edit/' + modelId;
                    
                    toggleEditParts(model.isCoat || false);
                    
                    const container = document.getElementById('editPartsFields');
                    container.innerHTML = '';
                    
                    if (model.isCoat && model.parts) {
                        model.parts.forEach((part, index) => {
                            addEditPartField(index, part);
                        });
                        for (let i = model.parts.length; i < 5; i++) {
                            addEditPartField(i, null);
                        }
                    }
                    
                    modal.style.display = 'flex';
                })
                .catch(err => {
                    alert('❌ Ошибка загрузки модели: ' + err.message);
                });
        }

        function closeEditModal() {
            document.getElementById('editModal').style.display = 'none';
            editModelId = null;
        }

        document.getElementById('editIsCoat').addEventListener('change', function() {
            toggleEditParts(this.checked);
            const container = document.getElementById('editPartsFields');
            container.innerHTML = '';
            if (this.checked) {
                for (let i = 0; i < 5; i++) {
                    addEditPartField(i, null);
                }
            }
        });

        function toggleEditParts(show) {
            document.getElementById('editPartsContainer').style.display = show ? 'block' : 'none';
        }

        // ---------- ФУНКЦИЯ ДОБАВЛЕНИЯ ПОЛЯ ДЛЯ ДЕТАЛЕЙ (С ВСТАВКОЙ ФОТО) ----------
        function addEditPartField(index, data) {
            const container = document.getElementById('editPartsFields');
            const div = document.createElement('div');
            div.style.cssText = 'border:1px solid rgba(201,169,89,0.1); padding:15px; border-radius:10px; margin-bottom:10px;';
            div.innerHTML = `
                <h4 style="color:#8892b0; font-size:13px;">Деталь ${index+1}</h4>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                    <input type="text" name="part_name_${index}" placeholder="Название" value="${data?.partName || ''}" style="padding:8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff;">
                    <input type="text" name="part_program_${index}" placeholder="Программа" value="${data?.program || ''}" style="padding:8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff;">
                    <input type="text" name="part_size_${index}" placeholder="Размер" value="${data?.size || ''}" style="padding:8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff;">
                    <input type="text" name="part_class_${index}" placeholder="Класс" value="${data?.className || ''}" style="padding:8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff;">
                    <input type="text" name="part_yarn_${index}" placeholder="Пряжа" value="${data?.yarn || ''}" style="padding:8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff; grid-column:1/3;">
                    <textarea name="part_image_${index}" class="edit-part-image-input" placeholder="Вставьте фото (Ctrl+V)" style="min-height:40px; padding:8px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:6px; color:#fff; font-family:inherit; grid-column:1/3;">${data?.image || ''}</textarea>
                </div>
                <div id="editPartPreview_${index}" style="display:${data?.image ? 'block' : 'none'}; margin-top:5px; grid-column:1/3;">
                    <img id="editPartPreviewImg_${index}" src="${data?.image || ''}" alt="Предпросмотр детали" style="max-width:150px; border-radius:8px; border:1px solid rgba(201,169,89,0.2);">
                </div>
            `;
            container.appendChild(div);
            
            // ОБРАБОТЧИК ДЛЯ ВСТАВКИ ФОТО В ДЕТАЛИ
            const textarea = div.querySelector('.edit-part-image-input');
            const previewDiv = div.querySelector(`#editPartPreview_${index}`);
            const previewImg = div.querySelector(`#editPartPreviewImg_${index}`);
            
            textarea.addEventListener('paste', function(e) {
                const items = e.clipboardData.items;
                let imageFound = false;
                
                for (let item of items) {
                    if (item.type.startsWith('image/')) {
                        const file = item.getAsFile();
                        const reader = new FileReader();
                        const self = this;
                        
                        reader.onload = function(event) {
                            self.value = event.target.result;
                            if (previewDiv && previewImg) {
                                previewImg.src = event.target.result;
                                previewDiv.style.display = 'block';
                            }
                            showNotification('✅ Фото детали вставлено!', 'success');
                        };
                        
                        reader.readAsDataURL(file);
                        imageFound = true;
                        e.preventDefault();
                        break;
                    }
                }
                
                if (!imageFound) {
                    showNotification('❌ Вставьте изображение (Ctrl+V)', 'error');
                }
            });
        }

        // Закрытие модалки по клику вне окна
        window.onclick = function(event) {
            const modal = document.getElementById('editModal');
            if (event.target === modal) closeEditModal();
        };

        // ---------- СТИЛИ ДЛЯ АНИМАЦИЙ УВЕДОМЛЕНИЙ ----------
        const styleSheet = document.createElement('style');
        styleSheet.textContent = `
            @keyframes slideInRight {
                from { opacity: 0; transform: translateX(60px); }
                to { opacity: 1; transform: translateX(0); }
            }
            @keyframes slideOutRight {
                from { opacity: 1; transform: translateX(0); }
                to { opacity: 0; transform: translateX(60px); }
            }
        `;
        document.head.appendChild(styleSheet);
    </script>
</body>
</html>
