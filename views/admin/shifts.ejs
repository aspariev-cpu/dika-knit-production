<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Смены — Админ-панель</title>
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background: #f5f5f5;
        }
        h1 {
            color: #333;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background: #fff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        th, td {
            padding: 12px;
            border: 1px solid #ddd;
            text-align: left;
        }
        th {
            background: #4a6fa5;
            color: white;
        }
        tr:nth-child(even) {
            background: #f9f9f9;
        }
        .time {
            white-space: nowrap;
        }
    </style>
</head>
<body>
    <h1>📋 Смены вязальщиков</h1>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Вязальщик</th>
                <th>Дата</th>
                <th>Начало смены</th>
                <th>Конец смены</th>
                <th>Машина</th>
                <th>Тип изделия</th>
                <th>Кол-во</th>
                <th>Заметки</th>
            </tr>
        </thead>
        <tbody>
            <% if (shifts && shifts.length > 0) { %>
                <% shifts.forEach(function(shift) { %>
                    <tr>
                        <td><%= shift.id %></td>
                        <td><%= shift.knitter_name %></td>
                        <td><%= shift.date %></td>
                        
                        <!-- ИСПРАВЛЕНО: форматируем start_time в московское время -->
                        <td class="time">
                            <%= new Date(shift.start_time).toLocaleString("ru-RU", {
                                timeZone: "Europe/Moscow",
                                hour: "2-digit",
                                minute: "2-digit",
                                second: "2-digit",
                                day: "2-digit",
                                month: "2-digit",
                                year: "numeric"
                            }) %>
                        </td>
                        
                        <!-- ИСПРАВЛЕНО: форматируем end_time в московское время -->
                        <td class="time">
                            <% if (shift.end_time) { %>
                                <%= new Date(shift.end_time).toLocaleString("ru-RU", {
                                    timeZone: "Europe/Moscow",
                                    hour: "2-digit",
                                    minute: "2-digit",
                                    second: "2-digit",
                                    day: "2-digit",
                                    month: "2-digit",
                                    year: "numeric"
                                }) %>
                            <% } else { %>
                                —
                            <% } %>
                        </td>
                        
                        <td><%= shift.machine_id || '—' %></td>
                        <td><%= shift.product_type || '—' %></td>
                        <td><%= shift.quantity || 0 %></td>
                        <td><%= shift.notes || '—' %></td>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr>
                    <td colspan="9" style="text-align: center;">Нет смен для отображения</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <br>
    <a href="/" style="display: inline-block; padding: 10px 20px; background: #4a6fa5; color: white; text-decoration: none; border-radius: 4px;">
        ← На главную
    </a>
</body>
</html>