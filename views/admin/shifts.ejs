<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Смены</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <a href="/admin" style="color:#c9a959; text-decoration:none; margin-right:15px;">← Назад</a>
            <span style="color:#8892b0;"><%= user.fullName %></span>
            <a href="/logout" style="color:#f87171; text-decoration:none;">Выйти</a>
        </div>
    </div>

    <div class="container">
        <h1 class="page-title">📊 Смены</h1>

        <div class="create-task" style="padding:20px; margin-bottom:30px;">
            <form action="/admin/shifts" method="get" style="display:flex; gap:15px; align-items:center; flex-wrap:wrap;">
                <input type="date" name="date" value="<%= date %>" style="padding:10px 16px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff;">
                <select name="shift" style="padding:10px 16px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff;">
                    <option value="day" <%= shift === 'day' ? 'selected' : '' %>>Дневная (8:00-20:00)</option>
                    <option value="night" <%= shift === 'night' ? 'selected' : '' %>>Ночная (20:00-8:00)</option>
                </select>
                <button type="submit" class="btn-submit" style="padding:10px 24px;">Показать</button>
                
                <!-- ✅ НОВАЯ КНОПКА ВЫГРУЗКИ -->
                <a href="/admin/shifts/export?date=<%= date %>&shift=<%= shift %>" class="btn-submit" style="padding:10px 24px; background:#4ade80; color:#0a0e1a; text-decoration:none; border-radius:10px; display:inline-block;">
                    📥 Выгрузить Excel
                </a>
            </form>
        </div>

        <div class="stats" style="margin-bottom:30px;">
            <div class="stat-card"><span class="stat-icon">👥</span><div class="stat-number"><%= summary ? summary.length : 0 %></div><div class="stat-label">Сотрудников работало</div></div>
            <div class="stat-card"><span class="stat-icon">🧶</span><div class="stat-number"><%= summary ? summary.reduce((sum, s) => sum + s.total, 0) : 0 %></div><div class="stat-label">Всего связано шт.</div></div>
            <div class="stat-card"><span class="stat-icon">📋</span><div class="stat-number"><%= operations ? operations.length : 0 %></div><div class="stat-label">Операций</div></div>
        </div>

        <div class="tasks-table">
            <table>
                <thead><tr><th>Сотрудник</th><th>Связано (шт.)</th><th>Станки</th></tr></thead>
                <tbody>
                    <% if (summary && summary.length > 0) { %>
                        <% summary.forEach(item => { %>
                            <tr>
                                <td><strong><%= item.name %></strong></td>
                                <td><%= item.total %></td>
                                <td><%= item.machines || '—' %></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="3" style="text-align:center; color:#475569;">За эту смену нет данных</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (operations && operations.length > 0) { %>
            <div style="margin-top:30px;">
                <h2 style="color:#c9a959; margin-bottom:20px;">📋 Детальный список операций</h2>
                <div class="tasks-table">
                    <table>
                        <thead>
                            <tr>
                                <th>Время</th>
                                <th>Сотрудник</th>
                                <th>Программа</th>
                                <th>Количество</th>
                                <th>Станок</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% operations.forEach(op => { %>
                                <tr>
                                    <td><%= new Date(op.createdAt).toLocaleString('ru-RU') %></td>
                                    <td><%= op.employee ? op.employee.fullName : '—' %></td>
                                    <td><%= op.Task && op.Task.Model ? op.Task.Model.program : '—' %></td>
                                    <td><%= op.quantity %></td>
                                    <td><%= op.machine ? '№' + op.machine.machineNumber : '—' %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
    </div>
</body>
</html>