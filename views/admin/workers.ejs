<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Сотрудники</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <a href="/admin" style="color:#c9a959; text-decoration:none; margin-right:15px;">← Назад</a>
            <span style="color:#8892b0;"><%= user.fullName %></span>
            <a href="/logout" style="color:#f87171; text-decoration:none;">Выйти</a>
        </div>
    </div>

    <div class="container">
        <h1 class="page-title">👥 Сотрудники</h1>

        <div class="create-task">
            <h2>➕ Добавить сотрудника</h2>
            <form action="/api/workers" method="post" class="form-grid">
                <input type="text" name="login" placeholder="Логин (номер)" required>
                <input type="text" name="fullName" placeholder="ФИО" required>
                <input type="text" name="password" placeholder="Пароль" required>
                <button type="submit" class="btn-submit">Добавить</button>
            </form>
        </div>

        <div class="tasks-table">
            <table>
                <thead><tr><th>Логин</th><th>ФИО</th><th>Действия</th></tr></thead>
                <tbody>
                    <% if (workers && workers.length > 0) { %>
                        <% workers.forEach(worker => { %>
                            <tr>
                                <td><%= worker.login %></td>
                                <td><%= worker.fullName %></td>
                                <td>
                                    <form action="/api/workers/delete/<%= worker.id %>" method="post" style="display:inline;" onsubmit="return confirm('Удалить сотрудника?')">
                                        <button type="submit" style="background:#f87171; color:#fff; border:none; padding:4px 12px; border-radius:6px; cursor:pointer;">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="3" style="text-align:center; color:#475569;">Нет сотрудников</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>