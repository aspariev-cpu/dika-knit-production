<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Сотрудники</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <a href="/admin" style="color:#c9a959; text-decoration:none; margin-right:15px;">← Назад</a>
            <span style="color:#aaa;"><%= user.fullName %></span>
            <a href="/logout" class="logout-btn">Выйти</a>
        </div>
    </div>

    <div class="container">
        <h1 class="page-title">👥 Сотрудники (вязальщики)</h1>

        <div class="create-task" style="margin-bottom:30px;">
            <h2 style="color:#c9a959; margin-bottom:20px;">➕ Добавить вязальщика</h2>
            <form action="/api/workers" method="post" class="form-grid">
                <input type="text" name="login" placeholder="Логин (номер, например: 002)" required>
                <input type="text" name="fullName" placeholder="ФИО (например: Петров П.П.)" required>
                <input type="text" name="password" placeholder="Пароль" required>
                <button type="submit" class="btn-submit">➕ Создать</button>
            </form>
        </div>

        <div class="tasks-table">
            <table>
                <thead>
                    <tr>
                        <th>Логин</th>
                        <th>ФИО</th>
                        <th>Дата создания</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (workers && workers.length > 0) { %>
                        <% workers.forEach(function(worker) { %>
                            <tr>
                                <td><strong><%= worker.login %></strong></td>
                                <td><%= worker.fullName %></td>
                                <td><%= new Date(worker.createdAt).toLocaleDateString('ru-RU') %></td>
                                <td>
                                    <form action="/api/workers/delete" method="post" style="display:inline;" 
                                          onsubmit="return confirm('Удалить сотрудника <%= worker.fullName %>?')">
                                        <input type="hidden" name="id" value="<%= worker.id %>">
                                        <button type="submit" class="btn btn-danger btn-sm" style="padding:6px 14px; font-size:12px; border-radius:8px; border:none; cursor:pointer; background:#ff6b6b; color:#fff;">🗑️ Удалить</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="text-align:center; color:#666; padding:40px;">
                                <p style="font-size:20px;">📭</p>
                                <p>Нет сотрудников</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>