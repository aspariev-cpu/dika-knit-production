<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Цвета</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <a href="/admin" style="color:#c9a959; text-decoration:none; margin-right:15px;">← Назад</a>
            <span style="color:#8892b0;"><%= user.fullName %></span>
            <a href="/logout" style="color:#f87171; text-decoration:none;">Выйти</a>
        </div>
    </div>

    <div class="container">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
            <h1 class="page-title" style="margin-bottom:0;">🎨 Цвета</h1>
            <a href="/admin/colors/export" class="btn-submit" style="padding:6px 16px; background:#4ade80; color:#0a0e1a; text-decoration:none; border-radius:8px; display:inline-block; font-weight:600; font-size:14px;">
                📥 Excel
            </a>
        </div>

        <div class="create-task" style="padding:20px;">
            <form action="/api/colors" method="post" style="display:flex; gap:10px; align-items:center;">
                <input type="text" name="name" placeholder="Название цвета (Красный, Синий, Чёрный...)" required style="flex:1; padding:10px 16px; background:rgba(255,255,255,0.07); border:1px solid rgba(201,169,89,0.1); border-radius:10px; color:#fff;">
                <button type="submit" class="btn-submit" style="padding:10px 24px;">➕ Добавить</button>
            </form>
        </div>

        <div class="tasks-table">
            <table>
                <thead><tr><th>Цвет</th><th>Действия</th></tr></thead>
                <tbody>
                    <% if (colors && colors.length > 0) { %>
                        <% colors.forEach(color => { %>
                            <tr>
                                <td><span style="display:inline-block; width:16px; height:16px; border-radius:4px; background:<%= color.name %>; border:1px solid #333; vertical-align:middle; margin-right:8px;"></span><%= color.name %></td>
                                <td>
                                    <form action="/api/colors/delete/<%= color.id %>" method="post" style="display:inline;" onsubmit="return confirm('Удалить?')">
                                        <button type="submit" style="background:#f87171; color:#fff; border:none; padding:4px 12px; border-radius:6px; cursor:pointer;">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="2" style="text-align:center; color:#475569;">Нет цветов</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
