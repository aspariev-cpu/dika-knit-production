<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dika Knit - Редактирование</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="header">
        <div class="logo">Dika <span>Knit</span></div>
        <div class="header-right">
            <a href="/admin" style="color:#c9a959; text-decoration:none; margin-right:15px;">← Назад</a>
            <span style="color:#aaa;"><%= user.fullName %></span>
            <a href="/logout" class="logout-btn">Выйти</a>
        </div>
    </div>

    <div class="container">
        <h1 class="page-title">✏️ Редактирование задания</h1>

        <div class="create-task">
            <form action="/api/tasks/edit/<%= task.id %>" method="post" class="form-grid">
                <input type="text" name="modelName" value="<%= task.modelName %>" placeholder="Модель (Алена)" required>
                <input type="text" name="programFile" value="<%= task.programFile %>" placeholder="Программа (turin.999)" required>
                <input type="text" name="color" value="<%= task.color %>" placeholder="Цвет" required>
                <select name="className" required>
                    <option value="Stoll" <%= task.className === 'Stoll' ? 'selected' : '' %>>Stoll</option>
                    <option value="5" <%= task.className === '5' ? 'selected' : '' %>>5</option>
                    <option value="7" <%= task.className === '7' ? 'selected' : '' %>>7</option>
                    <option value="12" <%= task.className === '12' ? 'selected' : '' %>>12</option>
                    <option value="14" <%= task.className === '14' ? 'selected' : '' %>>14</option>
                </select>
                <input type="number" name="planQuantity" value="<%= task.planQuantity %>" placeholder="Количество (шт.)" required>
                <div class="checkbox-group">
                    <input type="checkbox" name="isUrgent" id="urgent" <%= task.isUrgent ? 'checked' : '' %>>
                    <label for="urgent">🔥 Срочно</label>
                </div>
                <div style="display: flex; gap: 10px; grid-column: 1/-1;">
                    <button type="submit" class="btn-submit" style="flex:1;">💾 Сохранить изменения</button>
                    <a href="/admin" class="btn btn-secondary" style="flex:1; text-align:center; padding:12px; text-decoration:none; background:rgba(255,255,255,0.08); border-radius:10px; color:#fff;">Отмена</a>
                </div>
            </form>
        </div>

        <div style="background:rgba(255,255,255,0.03); border-radius:16px; padding:20px; border:1px solid rgba(255,215,0,0.05);">
            <h3 style="color:#888; font-weight:400; font-size:14px;">Информация о задании</h3>
            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(150px,1fr)); gap:10px; margin-top:10px;">
                <div><span style="color:#666;">ID:</span> <span style="color:#c9a959;">#<%= task.id %></span></div>
                <div><span style="color:#666;">Статус:</span> 
                    <span class="status-badge <%= task.status === 'completed' ? 'status-completed' : 'status-pending' %>">
                        <%= task.status === 'completed' ? '✅ Готов' : '⏳ В работе' %>
                    </span>
                </div>
                <div><span style="color:#666;">Создано:</span> <span style="color:#aaa;"><%= new Date(task.createdAt).toLocaleString('ru-RU') %></span></div>
            </div>
        </div>
    </div>
</body>
</html>